<div class="max-w-2xl">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-4"><%= statusPage ? 'Edit' : 'New' %> Status Page</h2>
    <form action="<%= statusPage ? '/status-pages/' + statusPage.id : '/status-pages' %>" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Title *</label>
        <input type="text" name="title" required value="<%= statusPage ? statusPage.title : '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" placeholder="My Service Status">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Slug * (URL path)</label>
        <div class="flex items-center gap-2">
          <span class="text-sm text-gray-400">/status/</span>
          <input type="text" name="slug" required value="<%= statusPage ? statusPage.slug : '' %>" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" placeholder="my-service">
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
        <textarea name="description" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" placeholder="Current status of our services"><%= statusPage ? statusPage.description || '' : '' %></textarea>
      </div>

      <!-- Monitor selection -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Select Monitors to Display</label>
        <div class="space-y-2 max-h-60 overflow-y-auto border border-gray-200 rounded-lg p-3">
          <% if (monitors.length === 0) { %>
            <p class="text-sm text-gray-400">No monitors available. Create some first.</p>
          <% } else { %>
            <% let currentWebsite = ''; %>
            <% monitors.forEach(function(m) { %>
              <% if (m.website_name !== currentWebsite) { %>
                <% currentWebsite = m.website_name; %>
                <div class="text-xs font-semibold text-gray-500 uppercase mt-2 first:mt-0"><%= m.website_name %></div>
              <% } %>
              <label class="flex items-center gap-2 py-1 px-2 rounded hover:bg-gray-50 cursor-pointer">
                <input type="checkbox" name="monitor_ids" value="<%= m.id %>"
                  <%= selectedMonitors.includes(m.id) ? 'checked' : '' %>
                  class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                <span class="text-sm text-gray-700"><%= m.name %></span>
              </label>
            <% }); %>
          <% } %>
        </div>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700"><%= statusPage ? 'Save Changes' : 'Create Status Page' %></button>
        <a href="/status-pages" class="px-6 py-2 rounded-lg font-medium text-gray-600 hover:bg-gray-100">Cancel</a>
      </div>
    </form>
  </div>
</div>
