<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>Uptime Monitor</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%234f46e5'/><path d='M8 22V14l4-4 4 6 4-8 4 12' stroke='white' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' fill='none'/><circle cx='8' cy='22' r='1.5' fill='white'/><circle cx='12' cy='10' r='1.5' fill='white'/><circle cx='16' cy='16' r='1.5' fill='white'/><circle cx='20' cy='8' r='1.5' fill='white'/><circle cx='24' cy='20' r='1.5' fill='white'/></svg>">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: { 50: '#eef2ff', 100: '#e0e7ff', 200: '#c7d2fe', 300: '#a5b4fc', 400: '#818cf8', 500: '#6366f1', 600: '#4f46e5', 700: '#4338ca', 800: '#3730a3', 900: '#312e81' },
            success: { 50: '#f0fdf4', 500: '#22c55e', 600: '#16a34a' },
            danger: { 50: '#fef2f2', 500: '#ef4444', 600: '#dc2626' },
          }
        }
      }
    }
  </script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    [x-cloak] { display: none !important; }
    #page-content { opacity: 0; transition: opacity 0.15s ease; }
    #page-content.loaded { opacity: 1; }
  </style>
</head>
<body class="bg-slate-50 min-h-screen">
  <%- include('../partials/flash') %>
  <div id="page-content">
    <%- body %>
  </div>
  <script>
    lucide.createIcons();
    requestAnimationFrame(() => {
      document.getElementById('page-content').classList.add('loaded');
    });
  </script>
</body>
</html>
