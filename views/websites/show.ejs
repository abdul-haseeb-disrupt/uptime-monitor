<div>
  <!-- Website header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
        <a href="/dashboard" class="hover:text-blue-600">Dashboard</a>
        <span>/</span>
        <span><%= website.name %></span>
      </div>
      <% if (website.base_url) { %>
        <p class="text-sm text-gray-400"><%= website.base_url %></p>
      <% } %>
    </div>
    <div class="flex gap-2">
      <a href="/monitors/new?website_id=<%= website.id %>" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        Add Monitor
      </a>
      <a href="/websites/<%= website.id %>/edit" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 border border-gray-200">Edit</a>
      <form action="/websites/<%= website.id %>/delete" method="POST" onsubmit="return confirm('Delete this website and ALL its monitors?')">
        <button type="submit" class="px-4 py-2 rounded-lg text-sm font-medium text-red-600 hover:bg-red-50 border border-red-200">Delete</button>
      </form>
    </div>
  </div>

  <!-- Monitors list -->
  <% if (monitors.length === 0) { %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center">
      <h3 class="text-lg font-medium text-gray-600 mb-2">No monitors yet</h3>
      <p class="text-gray-400 mb-4">Add monitors to track this website's uptime</p>
      <a href="/monitors/new?website_id=<%= website.id %>" class="inline-flex items-center gap-2 bg-blue-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700">Add Monitor</a>
    </div>
  <% } else { %>
    <div class="space-y-3">
      <% monitors.forEach(function(monitor) { %>
        <a href="/monitors/<%= monitor.id %>" class="block bg-white rounded-xl shadow-sm border border-gray-200 p-4 hover:shadow-md transition-shadow">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <% if (monitor.status === 'up') { %>
                <span class="w-3 h-3 rounded-full bg-green-500"></span>
              <% } else if (monitor.status === 'down') { %>
                <span class="w-3 h-3 rounded-full bg-red-500 animate-pulse"></span>
              <% } else if (monitor.status === 'paused') { %>
                <span class="w-3 h-3 rounded-full bg-gray-300"></span>
              <% } else { %>
                <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
              <% } %>
              <div>
                <div class="font-medium text-gray-800"><%= monitor.name %></div>
                <div class="text-sm text-gray-400">
                  <%= monitor.type.toUpperCase() %>
                  <% if (monitor.url) { %> &middot; <%= monitor.url %><% } %>
                  <% if (monitor.hostname) { %> &middot; <%= monitor.hostname %><% if (monitor.port) { %>:<%= monitor.port %><% } %><% } %>
                </div>
              </div>
            </div>
            <div class="text-right">
              <span class="px-2 py-0.5 rounded text-xs font-medium
                <%= monitor.status === 'up' ? 'bg-green-100 text-green-700' :
                   monitor.status === 'down' ? 'bg-red-100 text-red-700' :
                   monitor.status === 'paused' ? 'bg-gray-100 text-gray-500' :
                   'bg-yellow-100 text-yellow-700' %>"><%= monitor.status.toUpperCase() %></span>
              <% if (monitor.lastCheck) { %>
                <div class="text-xs text-gray-400 mt-1"><%= formatResponseTime(monitor.lastCheck.response_time) %></div>
              <% } %>
            </div>
          </div>
        </a>
      <% }); %>
    </div>
  <% } %>
</div>
