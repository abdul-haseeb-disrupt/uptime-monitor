<div class="max-w-2xl">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-4">Edit Monitor</h2>
    <form action="/monitors/<%= monitor.id %>" method="POST" class="space-y-4">

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Monitor Name *</label>
        <input type="text" name="name" required value="<%= monitor.name %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
        <input type="text" value="<%= monitor.type.toUpperCase() %>" disabled class="w-full px-3 py-2 border border-gray-200 rounded-lg bg-gray-50 text-gray-500">
      </div>

      <% if (monitor.type === 'http' || monitor.type === 'keyword') { %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">URL *</label>
          <input type="url" name="url" value="<%= monitor.url || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
        </div>
      <% } %>

      <% if (monitor.type === 'keyword') { %>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Keyword</label>
            <input type="text" name="keyword" value="<%= monitor.keyword || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Keyword Should</label>
            <select name="keyword_type" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
              <option value="exists" <%= monitor.keyword_type === 'exists' ? 'selected' : '' %>>Exist</option>
              <option value="not_exists" <%= monitor.keyword_type === 'not_exists' ? 'selected' : '' %>>Not Exist</option>
            </select>
          </div>
        </div>
      <% } %>

      <% if (monitor.type === 'ping' || monitor.type === 'port') { %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Hostname</label>
          <input type="text" name="hostname" value="<%= monitor.hostname || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
        </div>
      <% } %>

      <% if (monitor.type === 'port') { %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Port</label>
          <input type="number" name="port" value="<%= monitor.port || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
        </div>
      <% } %>

      <% if (monitor.type === 'heartbeat') { %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Expected Interval (seconds)</label>
          <input type="number" name="heartbeat_interval" value="<%= monitor.heartbeat_interval || 3600 %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
        </div>
      <% } %>

      <div class="grid grid-cols-2 gap-4 pt-4 border-t border-gray-100">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Check Interval</label>
          <select name="interval_seconds" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
            <% [60,120,300,600,900,1800,3600].forEach(function(s) { %>
              <option value="<%= s %>" <%= monitor.interval_seconds === s ? 'selected' : '' %>><%= s < 3600 ? (s/60) + ' minutes' : '1 hour' %></option>
            <% }); %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Timeout</label>
          <select name="timeout_seconds" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
            <% [10,30,60].forEach(function(s) { %>
              <option value="<%= s %>" <%= monitor.timeout_seconds === s ? 'selected' : '' %>><%= s %> seconds</option>
            <% }); %>
          </select>
        </div>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700">Save Changes</button>
        <a href="/monitors/<%= monitor.id %>" class="px-6 py-2 rounded-lg font-medium text-gray-600 hover:bg-gray-100">Cancel</a>
      </div>
    </form>
  </div>
</div>
