<div class="max-w-7xl mx-auto py-8 px-4 fade-in"
  x-data="{ activeProject: '<%= websites.length > 0 ? websites[0].id : '' %>', device: 'desktop', uptimeRange: '24h' }">

  <!-- Header -->
  <div class="text-center mb-6">
    <h1 class="text-2xl font-bold text-slate-800">Status Overview</h1>
    <p class="text-slate-400 text-sm mt-1">Live status across all projects</p>
  </div>

  <% if (websites.length === 0) { %>
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-12 text-center">
      <p class="text-slate-400">No projects yet</p>
    </div>
  <% } else { %>

    <!-- Project Selector -->
    <div class="flex flex-wrap gap-2 mb-5 justify-center">
      <% websites.forEach(function(website) { %>
        <% var st = projectStatus[website.id]; %>
        <button @click="activeProject = '<%= website.id %>'"
          :class="activeProject === '<%= website.id %>' ? 'bg-primary-600 text-white shadow-sm shadow-primary-500/25' : 'bg-white text-slate-600 border border-slate-200 hover:border-primary-300 hover:text-primary-600'"
          class="px-4 py-2 rounded-xl text-sm font-semibold transition-all flex items-center gap-2">
          <span class="w-2 h-2 rounded-full flex-shrink-0
            <%= st === 'operational' ? 'bg-emerald-400' : st === 'major_outage' ? 'bg-red-400' : st === 'partial' ? 'bg-amber-400' : 'bg-slate-300' %>"></span>
          <%= website.name %>
          <span class="text-[10px] opacity-70">(<%= website.monitor_count %>)</span>
        </button>
      <% }); %>
    </div>

    <!-- Filters (shared across projects) -->
    <div class="flex items-center justify-between mb-4 flex-wrap gap-3">
      <div class="flex items-center gap-1.5">
        <span class="text-xs font-medium text-slate-500">Period:</span>
        <div class="inline-flex items-center bg-slate-100 rounded-lg p-0.5">
          <% ['24h', '7d', '30d', '90d'].forEach(function(r) { %>
            <button @click="uptimeRange = '<%= r %>'"
              :class="uptimeRange === '<%= r %>' ? 'bg-white shadow-sm text-slate-800' : 'text-slate-500 hover:text-slate-700'"
              class="px-2.5 py-1 rounded-md text-[11px] font-semibold transition-all"><%= r === '24h' ? '24 Hours' : r === '7d' ? '7 Days' : r === '30d' ? '30 Days' : '90 Days' %></button>
          <% }); %>
        </div>
      </div>
      <div class="inline-flex items-center bg-slate-100 rounded-lg p-0.5">
        <button @click="device = 'desktop'"
          :class="device === 'desktop' ? 'bg-white shadow-sm text-slate-800' : 'text-slate-500 hover:text-slate-700'"
          class="flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[11px] font-semibold transition-all">
          <i data-lucide="monitor" class="w-3.5 h-3.5"></i> Desktop
        </button>
        <button @click="device = 'mobile'"
          :class="device === 'mobile' ? 'bg-white shadow-sm text-slate-800' : 'text-slate-500 hover:text-slate-700'"
          class="flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[11px] font-semibold transition-all">
          <i data-lucide="smartphone" class="w-3.5 h-3.5"></i> Mobile
        </button>
      </div>
    </div>

    <!-- Per-project sections -->
    <% websites.forEach(function(website) { %>
      <% var monitors = projectMonitors[website.id] || []; %>
      <% var incidents = projectIncidents[website.id] || []; %>
      <% var st = projectStatus[website.id]; %>

      <div x-show="activeProject === '<%= website.id %>'" x-cloak>
        <!-- Overall status -->
        <div class="rounded-xl p-3 mb-6 text-center font-semibold flex items-center justify-center gap-2 text-sm
          <%= st === 'operational' ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' :
             st === 'major_outage' ? 'bg-red-50 text-red-700 border border-red-200' :
             st === 'partial' ? 'bg-amber-50 text-amber-700 border border-amber-200' :
             'bg-slate-50 text-slate-600 border border-slate-200' %>">
          <% if (st === 'operational') { %>
            <i data-lucide="check-circle-2" class="w-4 h-4"></i> All Systems Operational
          <% } else if (st === 'major_outage') { %>
            <i data-lucide="alert-triangle" class="w-4 h-4"></i> Major Outage Detected
          <% } else if (st === 'partial') { %>
            <i data-lucide="alert-circle" class="w-4 h-4"></i> Partial Outage
          <% } else { %>
            <i data-lucide="circle" class="w-4 h-4"></i> No Pages Configured
          <% } %>
          <span class="text-xs font-normal ml-2 opacity-70">Updated every 5 min</span>
        </div>

        <% if (monitors.length > 0) { %>
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden mb-4">
            <div class="overflow-x-auto">
              <table class="w-full">
                <thead>
                  <tr class="bg-slate-50 border-b border-slate-200">
                    <th class="text-left px-4 py-3 text-xs font-semibold text-slate-600">Service</th>
                    <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600" colspan="2">Uptime</th>
                    <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">Performance</th>
                    <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">Accessibility</th>
                    <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">Best Practices</th>
                    <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">SEO</th>
                    <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">LCP</th>
                    <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">CLS</th>
                  </tr>
                </thead>
                <tbody>
                  <% monitors.forEach(function(monitor, index) { %>
                    <%
                      var psData = {};
                      if (monitor.pagespeed) {
                        ['24h','7d','30d','90d'].forEach(function(p) {
                          psData[p] = {};
                          ['mobile','desktop'].forEach(function(s) {
                            var d = monitor.pagespeed[p] ? monitor.pagespeed[p][s] : null;
                            psData[p][s] = d ? {
                              performance: parseInt(d.performance) || null,
                              accessibility: parseInt(d.accessibility) || null,
                              best_practices: parseInt(d.best_practices) || null,
                              seo: parseInt(d.seo) || null,
                              lcp: d.lcp ? parseFloat(d.lcp) : null,
                              cls: d.cls !== null && d.cls !== undefined ? parseFloat(d.cls) : null
                            } : null;
                          });
                        });
                      }
                    %>
                    <tr class="<%= index < monitors.length - 1 ? 'border-b border-slate-100' : '' %> hover:bg-slate-50/50 transition-colors"
                      x-data='{
                        stats: <%= JSON.stringify({
                          uptime_24h: monitor.stats ? monitor.stats.uptime_24h : null,
                          uptime_7d: monitor.stats ? monitor.stats.uptime_7d : null,
                          uptime_30d: monitor.stats ? monitor.stats.uptime_30d : null,
                          uptime_90d: monitor.stats ? monitor.stats.uptime_90d : null
                        }) %>,
                        ps: <%= JSON.stringify(psData) %>,
                        getPS(field) {
                          let d = this.ps[uptimeRange] ? this.ps[uptimeRange][device] : null;
                          return d ? d[field] : null;
                        },
                        scoreColor(v) { if(!v&&v!==0) return "text-slate-300"; if(v>=90) return "text-emerald-600 bg-emerald-50"; if(v>=50) return "text-amber-600 bg-amber-50"; return "text-red-600 bg-red-50"; },
                        lcpColor(v) { if(!v) return "text-slate-300"; if(v<=2.5) return "text-emerald-600"; if(v<=4) return "text-amber-600"; return "text-red-600"; },
                        clsColor(v) { if(v===null||v===undefined) return "text-slate-300"; if(v<=0.1) return "text-emerald-600"; if(v<=0.25) return "text-amber-600"; return "text-red-600"; }
                      }'>
                      <td class="px-4 py-2.5">
                        <div class="flex items-center gap-2 min-w-0">
                          <span class="w-2 h-2 rounded-full flex-shrink-0 <%= monitor.status === 'up' ? 'bg-emerald-500' : monitor.status === 'down' ? 'bg-red-500 status-pulse' : 'bg-slate-300' %>"></span>
                          <div class="min-w-0">
                            <div class="text-sm font-medium text-slate-700 truncate max-w-[200px]"><%= monitor.name %></div>
                            <% if (monitor.url) { %>
                              <div class="text-[10px] text-slate-400 truncate max-w-[200px]"><%= monitor.url.replace(/^https?:\/\//, '') %></div>
                            <% } %>
                          </div>
                        </div>
                      </td>

                      <td class="px-2 py-2.5">
                        <% ['24h', '7', '30', '90'].forEach(function(period) { %>
                          <div x-show="uptimeRange === '<%= period === '24h' ? '24h' : period + 'd' %>'" x-cloak
                            class="flex gap-[2px] items-end h-7 min-w-[280px] mx-auto">
                            <% (monitor.dailyUptime[period] || []).forEach(function(day) { %>
                              <% let c = 'bg-slate-200'; if (day.uptime !== null) { if (day.uptime >= 99.9) c = 'bg-emerald-500'; else if (day.uptime >= 99) c = 'bg-emerald-400'; else if (day.uptime >= 95) c = 'bg-amber-400'; else c = 'bg-red-500'; } %>
                              <div class="<%= c %> rounded-[2px] flex-1 hover:opacity-75 transition-opacity" style="min-width:2px; height:<%= day.uptime !== null ? Math.max(8, (day.uptime/100)*28) : 4 %>px;" title="<%= day.day %>: <%= day.uptime !== null ? day.uptime.toFixed(1)+'%' : 'No data' %>"></div>
                            <% }); %>
                          </div>
                        <% }); %>
                      </td>

                      <td class="px-2 py-2.5 text-center">
                        <span class="text-xs font-bold"
                          :class="{
                            'text-emerald-600': stats['uptime_' + uptimeRange] >= 99,
                            'text-red-600': stats['uptime_' + uptimeRange] && stats['uptime_' + uptimeRange] < 99,
                            'text-slate-400': !stats['uptime_' + uptimeRange]
                          }"
                          x-text="stats['uptime_' + uptimeRange] ? stats['uptime_' + uptimeRange] + '%' : '-'"></span>
                      </td>

                      <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold px-1.5 py-0.5 rounded" :class="scoreColor(getPS('performance'))" x-text="getPS('performance') !== null ? getPS('performance') : '-'"></span></td>
                      <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold px-1.5 py-0.5 rounded" :class="scoreColor(getPS('accessibility'))" x-text="getPS('accessibility') !== null ? getPS('accessibility') : '-'"></span></td>
                      <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold px-1.5 py-0.5 rounded" :class="scoreColor(getPS('best_practices'))" x-text="getPS('best_practices') !== null ? getPS('best_practices') : '-'"></span></td>
                      <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold px-1.5 py-0.5 rounded" :class="scoreColor(getPS('seo'))" x-text="getPS('seo') !== null ? getPS('seo') : '-'"></span></td>
                      <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold" :class="lcpColor(getPS('lcp'))" x-text="getPS('lcp') !== null ? getPS('lcp') + 's' : '-'"></span></td>
                      <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold" :class="clsColor(getPS('cls'))" x-text="getPS('cls') !== null ? getPS('cls') : '-'"></span></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Legend -->
          <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-[10px] text-slate-400 mb-6">
            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-sm bg-emerald-500"></span> Good (90+)</span>
            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-sm bg-amber-400"></span> Needs Work (50-89)</span>
            <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-sm bg-red-500"></span> Poor (&lt;50)</span>
            <span class="text-slate-300">|</span>
            <span>LCP &le;2.5s Good</span>
            <span>CLS &le;0.1 Good</span>
          </div>
        <% } else { %>
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-12 text-center mb-6">
            <p class="text-slate-400">No pages in this project</p>
          </div>
        <% } %>

        <!-- Incidents -->
        <% if (incidents.length > 0) { %>
          <div class="mb-6">
            <h2 class="text-sm font-semibold text-slate-600 mb-3 flex items-center gap-1.5">
              <i data-lucide="alert-circle" class="w-4 h-4"></i> Recent Incidents
            </h2>
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 divide-y divide-slate-100">
              <% incidents.forEach(function(incident) { %>
                <div class="px-4 py-3 flex items-center justify-between">
                  <div class="flex items-center gap-2 min-w-0">
                    <i data-lucide="<%= incident.resolved_at ? 'check-circle-2' : 'alert-triangle' %>" class="w-3.5 h-3.5 flex-shrink-0 <%= incident.resolved_at ? 'text-emerald-500' : 'text-red-500' %>"></i>
                    <span class="text-sm font-medium text-slate-700 truncate"><%= incident.monitor_name %></span>
                  </div>
                  <div class="flex items-center gap-2 flex-shrink-0">
                    <span class="text-xs text-slate-400"><%= new Date(incident.started_at).toLocaleDateString() %></span>
                    <span class="text-[10px] px-1.5 py-0.5 rounded font-semibold <%= incident.resolved_at ? 'bg-emerald-50 text-emerald-600' : 'bg-red-50 text-red-600' %>"><%= incident.resolved_at ? 'Resolved' : 'Active' %></span>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>
        <% } %>
      </div>
    <% }); %>
  <% } %>

  <div class="text-center text-xs text-slate-400 pt-4 pb-6 flex items-center justify-center gap-1.5">
    <i data-lucide="activity" class="w-3 h-3"></i> Powered by Uptime Monitor
  </div>
  <meta http-equiv="refresh" content="300">
</div>

<style>
  .status-pulse { animation: pulse-ring 2s cubic-bezier(0.4,0,0.6,1) infinite; }
  @keyframes pulse-ring { 0%,100% { opacity:1; } 50% { opacity:0.5; } }
  [x-cloak] { display: none !important; }
</style>
