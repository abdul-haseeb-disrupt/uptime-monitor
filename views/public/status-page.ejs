<div class="max-w-7xl mx-auto py-8 px-4 fade-in" x-data="{ device: 'desktop', uptimeRange: '24h' }">
  <!-- Header -->
  <div class="text-center mb-6">
    <h1 class="text-2xl font-bold text-slate-800"><%= statusPage.title %></h1>
    <% if (statusPage.description) { %>
      <p class="text-slate-400 text-sm mt-1"><%= statusPage.description %></p>
    <% } %>
  </div>

  <!-- Overall status banner -->
  <div class="rounded-xl p-3 mb-6 text-center font-semibold flex items-center justify-center gap-2 text-sm
    <%= overallStatus === 'operational' ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' :
       overallStatus === 'major_outage' ? 'bg-red-50 text-red-700 border border-red-200' :
       'bg-amber-50 text-amber-700 border border-amber-200' %>">
    <% if (overallStatus === 'operational') { %>
      <i data-lucide="check-circle-2" class="w-4 h-4"></i> All Systems Operational
    <% } else if (overallStatus === 'major_outage') { %>
      <i data-lucide="alert-triangle" class="w-4 h-4"></i> Major Outage Detected
    <% } else { %>
      <i data-lucide="alert-circle" class="w-4 h-4"></i> Partial Outage
    <% } %>
    <span class="text-xs font-normal ml-2 opacity-70">Updated every 60s</span>
  </div>

  <%
    function scoreClass(val) {
      if (val === null || val === undefined) return 'text-slate-300';
      if (val >= 90) return 'text-emerald-600 bg-emerald-50';
      if (val >= 50) return 'text-amber-600 bg-amber-50';
      return 'text-red-600 bg-red-50';
    }
    function lcpClass(val) {
      if (!val) return 'text-slate-300';
      if (val <= 2.5) return 'text-emerald-600';
      if (val <= 4) return 'text-amber-600';
      return 'text-red-600';
    }
    function clsClass(val) {
      if (val === null || val === undefined) return 'text-slate-300';
      if (val <= 0.1) return 'text-emerald-600';
      if (val <= 0.25) return 'text-amber-600';
      return 'text-red-600';
    }
  %>

  <% if (monitors.length > 0) { %>

    <!-- Filters Row -->
    <div class="flex items-center justify-between mb-4 flex-wrap gap-3">
      <div class="flex items-center gap-3">
        <!-- Uptime Range Filter -->
        <div class="flex items-center gap-1.5">
          <span class="text-xs font-medium text-slate-500">Uptime:</span>
          <div class="inline-flex items-center bg-slate-100 rounded-lg p-0.5">
            <% ['24h', '7d', '30d', '90d'].forEach(function(r) { %>
              <button @click="uptimeRange = '<%= r %>'"
                :class="uptimeRange === '<%= r %>' ? 'bg-white shadow-sm text-slate-800' : 'text-slate-500 hover:text-slate-700'"
                class="px-2.5 py-1 rounded-md text-[11px] font-semibold transition-all"><%= r === '24h' ? '24 Hours' : r === '7d' ? '7 Days' : r === '30d' ? '30 Days' : '90 Days' %></button>
            <% }); %>
          </div>
        </div>
      </div>

      <!-- Device Toggle -->
      <div class="inline-flex items-center bg-slate-100 rounded-lg p-0.5">
        <button @click="device = 'desktop'"
          :class="device === 'desktop' ? 'bg-white shadow-sm text-slate-800' : 'text-slate-500 hover:text-slate-700'"
          class="flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[11px] font-semibold transition-all">
          <i data-lucide="monitor" class="w-3.5 h-3.5"></i> Desktop
        </button>
        <button @click="device = 'mobile'"
          :class="device === 'mobile' ? 'bg-white shadow-sm text-slate-800' : 'text-slate-500 hover:text-slate-700'"
          class="flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[11px] font-semibold transition-all">
          <i data-lucide="smartphone" class="w-3.5 h-3.5"></i> Mobile
        </button>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden mb-4">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-600">Service</th>
              <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">
                <span x-text="uptimeRange === '24h' ? 'Last 24 Hours' : uptimeRange === '7d' ? 'Last 7 Days' : uptimeRange === '30d' ? 'Last 30 Days' : 'Last 90 Days'"></span> Uptime
              </th>
              <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">
                Uptime <span x-text="uptimeRange === '24h' ? '(24h)' : uptimeRange === '7d' ? '(7d)' : uptimeRange === '30d' ? '(30d)' : '(90d)'"></span>
              </th>
              <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">Performance</th>
              <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">Accessibility</th>
              <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">Best Practices</th>
              <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">SEO</th>
              <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">LCP</th>
              <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">CLS</th>
            </tr>
          </thead>
          <tbody>
            <% monitors.forEach(function(monitor, index) { %>
              <%
                var mob = monitor.pagespeed ? monitor.pagespeed.mobile : null;
                var desk = monitor.pagespeed ? monitor.pagespeed.desktop : null;
              %>
              <tr class="<%= index < monitors.length - 1 ? 'border-b border-slate-100' : '' %> hover:bg-slate-50/50 transition-colors"
                x-data="{
                  stats: <%= JSON.stringify({
                    uptime_24h: monitor.stats ? monitor.stats.uptime_24h : null,
                    uptime_7d: monitor.stats ? monitor.stats.uptime_7d : null,
                    uptime_30d: monitor.stats ? monitor.stats.uptime_30d : null,
                    uptime_90d: monitor.stats ? monitor.stats.uptime_90d : null
                  }) %>
                }">
                <!-- Name + URL -->
                <td class="px-4 py-2.5">
                  <div class="flex items-center gap-2 min-w-0">
                    <span class="w-2 h-2 rounded-full flex-shrink-0
                      <%= monitor.status === 'up' ? 'bg-emerald-500' : monitor.status === 'down' ? 'bg-red-500 status-pulse' : 'bg-slate-300' %>"></span>
                    <div class="min-w-0">
                      <div class="text-sm font-medium text-slate-700 truncate max-w-[200px]"><%= monitor.display_name || monitor.name %></div>
                      <% if (monitor.url) { %>
                        <div class="text-[10px] text-slate-400 truncate max-w-[200px]"><%= monitor.url.replace(/^https?:\/\//, '') %></div>
                      <% } %>
                    </div>
                  </div>
                </td>

                <!-- Uptime bar (switches by range) -->
                <td class="px-2 py-2.5">
                  <% ['7', '30', '90'].forEach(function(days) { %>
                    <div x-show="uptimeRange === '<%= days === '7' ? '7d' : days === '30' ? '30d' : '90d' %>' || (uptimeRange === '24h' && '<%= days %>' === '7')"
                      x-cloak
                      class="flex gap-[2px] items-end h-7 min-w-[280px] mx-auto">
                      <% var du = monitor.dailyUptime[days] || []; %>
                      <% du.forEach(function(day) { %>
                        <%
                          let c = 'bg-slate-200';
                          if (day.uptime !== null) {
                            if (day.uptime >= 99.9) c = 'bg-emerald-500';
                            else if (day.uptime >= 99) c = 'bg-emerald-400';
                            else if (day.uptime >= 95) c = 'bg-amber-400';
                            else c = 'bg-red-500';
                          }
                        %>
                        <div class="<%= c %> rounded-[2px] flex-1 hover:opacity-75 transition-opacity" style="min-width:2px; height:<%= day.uptime !== null ? Math.max(8, (day.uptime/100)*28) : 4 %>px;" title="<%= day.day %>: <%= day.uptime !== null ? day.uptime.toFixed(1)+'%' : 'No data' %>"></div>
                      <% }); %>
                    </div>
                  <% }); %>
                </td>

                <!-- Uptime % (dynamic) -->
                <td class="px-2 py-2.5 text-center">
                  <template x-if="uptimeRange === '24h'">
                    <span class="text-xs font-bold" :class="stats.uptime_24h >= 99 ? 'text-emerald-600' : stats.uptime_24h < 99 ? 'text-red-600' : 'text-slate-400'" x-text="stats.uptime_24h ? stats.uptime_24h + '%' : '-'"></span>
                  </template>
                  <template x-if="uptimeRange === '7d'">
                    <span class="text-xs font-bold" :class="stats.uptime_7d >= 99 ? 'text-emerald-600' : stats.uptime_7d < 99 ? 'text-red-600' : 'text-slate-400'" x-text="stats.uptime_7d ? stats.uptime_7d + '%' : '-'"></span>
                  </template>
                  <template x-if="uptimeRange === '30d'">
                    <span class="text-xs font-bold" :class="stats.uptime_30d >= 99 ? 'text-emerald-600' : stats.uptime_30d < 99 ? 'text-red-600' : 'text-slate-400'" x-text="stats.uptime_30d ? stats.uptime_30d + '%' : '-'"></span>
                  </template>
                  <template x-if="uptimeRange === '90d'">
                    <span class="text-xs font-bold" :class="stats.uptime_90d >= 99 ? 'text-emerald-600' : stats.uptime_90d < 99 ? 'text-red-600' : 'text-slate-400'" x-text="stats.uptime_90d ? stats.uptime_90d + '%' : '-'"></span>
                  </template>
                </td>

                <!-- Desktop scores (default) -->
                <template x-if="device === 'desktop'">
                  <td class="px-2 py-2.5 text-center"><% if (desk) { %><span class="text-[11px] font-bold px-1.5 py-0.5 rounded <%= scoreClass(desk.performance) %>"><%= desk.performance %></span><% } else { %><span class="text-xs text-slate-300">-</span><% } %></td>
                </template>
                <template x-if="device === 'desktop'">
                  <td class="px-2 py-2.5 text-center"><% if (desk) { %><span class="text-[11px] font-bold px-1.5 py-0.5 rounded <%= scoreClass(desk.accessibility) %>"><%= desk.accessibility %></span><% } else { %><span class="text-xs text-slate-300">-</span><% } %></td>
                </template>
                <template x-if="device === 'desktop'">
                  <td class="px-2 py-2.5 text-center"><% if (desk) { %><span class="text-[11px] font-bold px-1.5 py-0.5 rounded <%= scoreClass(desk.best_practices) %>"><%= desk.best_practices %></span><% } else { %><span class="text-xs text-slate-300">-</span><% } %></td>
                </template>
                <template x-if="device === 'desktop'">
                  <td class="px-2 py-2.5 text-center"><% if (desk) { %><span class="text-[11px] font-bold px-1.5 py-0.5 rounded <%= scoreClass(desk.seo) %>"><%= desk.seo %></span><% } else { %><span class="text-xs text-slate-300">-</span><% } %></td>
                </template>
                <template x-if="device === 'desktop'">
                  <td class="px-2 py-2.5 text-center"><% if (desk && desk.lcp) { %><span class="text-[11px] font-bold <%= lcpClass(desk.lcp) %>"><%= desk.lcp %>s</span><% } else { %><span class="text-xs text-slate-300">-</span><% } %></td>
                </template>
                <template x-if="device === 'desktop'">
                  <td class="px-2 py-2.5 text-center"><% if (desk && desk.cls !== null) { %><span class="text-[11px] font-bold <%= clsClass(desk.cls) %>"><%= desk.cls %></span><% } else { %><span class="text-xs text-slate-300">-</span><% } %></td>
                </template>

                <!-- Mobile scores -->
                <template x-if="device === 'mobile'">
                  <td class="px-2 py-2.5 text-center"><% if (mob) { %><span class="text-[11px] font-bold px-1.5 py-0.5 rounded <%= scoreClass(mob.performance) %>"><%= mob.performance %></span><% } else { %><span class="text-xs text-slate-300">-</span><% } %></td>
                </template>
                <template x-if="device === 'mobile'">
                  <td class="px-2 py-2.5 text-center"><% if (mob) { %><span class="text-[11px] font-bold px-1.5 py-0.5 rounded <%= scoreClass(mob.accessibility) %>"><%= mob.accessibility %></span><% } else { %><span class="text-xs text-slate-300">-</span><% } %></td>
                </template>
                <template x-if="device === 'mobile'">
                  <td class="px-2 py-2.5 text-center"><% if (mob) { %><span class="text-[11px] font-bold px-1.5 py-0.5 rounded <%= scoreClass(mob.best_practices) %>"><%= mob.best_practices %></span><% } else { %><span class="text-xs text-slate-300">-</span><% } %></td>
                </template>
                <template x-if="device === 'mobile'">
                  <td class="px-2 py-2.5 text-center"><% if (mob) { %><span class="text-[11px] font-bold px-1.5 py-0.5 rounded <%= scoreClass(mob.seo) %>"><%= mob.seo %></span><% } else { %><span class="text-xs text-slate-300">-</span><% } %></td>
                </template>
                <template x-if="device === 'mobile'">
                  <td class="px-2 py-2.5 text-center"><% if (mob && mob.lcp) { %><span class="text-[11px] font-bold <%= lcpClass(mob.lcp) %>"><%= mob.lcp %>s</span><% } else { %><span class="text-xs text-slate-300">-</span><% } %></td>
                </template>
                <template x-if="device === 'mobile'">
                  <td class="px-2 py-2.5 text-center"><% if (mob && mob.cls !== null) { %><span class="text-[11px] font-bold <%= clsClass(mob.cls) %>"><%= mob.cls %></span><% } else { %><span class="text-xs text-slate-300">-</span><% } %></td>
                </template>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Legend -->
    <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-[10px] text-slate-400 mb-6">
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-sm bg-emerald-500"></span> Good (90+)</span>
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-sm bg-amber-400"></span> Needs Work (50-89)</span>
      <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-sm bg-red-500"></span> Poor (&lt;50)</span>
      <span class="text-slate-300">|</span>
      <span>LCP &le;2.5s Good</span>
      <span>CLS &le;0.1 Good</span>
    </div>
  <% } %>

  <!-- Recent Incidents -->
  <% if (incidents.length > 0) { %>
    <div class="mb-6">
      <h2 class="text-sm font-semibold text-slate-600 mb-3 flex items-center gap-1.5">
        <i data-lucide="alert-circle" class="w-4 h-4"></i> Recent Incidents
      </h2>
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 divide-y divide-slate-100">
        <% incidents.forEach(function(incident) { %>
          <div class="px-4 py-3 flex items-center justify-between">
            <div class="flex items-center gap-2 min-w-0">
              <i data-lucide="<%= incident.resolved_at ? 'check-circle-2' : 'alert-triangle' %>" class="w-3.5 h-3.5 flex-shrink-0 <%= incident.resolved_at ? 'text-emerald-500' : 'text-red-500' %>"></i>
              <span class="text-sm font-medium text-slate-700 truncate"><%= incident.monitor_name %></span>
            </div>
            <div class="flex items-center gap-2 flex-shrink-0">
              <span class="text-xs text-slate-400"><%= new Date(incident.started_at).toLocaleDateString() %></span>
              <span class="text-[10px] px-1.5 py-0.5 rounded font-semibold
                <%= incident.resolved_at ? 'bg-emerald-50 text-emerald-600' : 'bg-red-50 text-red-600' %>">
                <%= incident.resolved_at ? 'Resolved' : 'Active' %>
              </span>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  <% } %>

  <div class="text-center text-xs text-slate-400 pt-4 pb-6 flex items-center justify-center gap-1.5">
    <i data-lucide="activity" class="w-3 h-3"></i> Powered by Uptime Monitor
  </div>
  <meta http-equiv="refresh" content="60">
</div>

<style>
  .status-pulse { animation: pulse-ring 2s cubic-bezier(0.4,0,0.6,1) infinite; }
  @keyframes pulse-ring { 0%,100% { opacity:1; } 50% { opacity:0.5; } }
  [x-cloak] { display: none !important; }
</style>
