<div class="max-w-3xl mx-auto py-8 px-4">
  <!-- Header -->
  <div class="text-center mb-8">
    <h1 class="text-3xl font-bold text-gray-800"><%= statusPage.title %></h1>
    <% if (statusPage.description) { %>
      <p class="text-gray-500 mt-2"><%= statusPage.description %></p>
    <% } %>
  </div>

  <!-- Overall status -->
  <div class="rounded-xl p-4 mb-8 text-center font-semibold text-lg
    <%= overallStatus === 'operational' ? 'bg-green-50 text-green-700 border border-green-200' :
       overallStatus === 'major_outage' ? 'bg-red-50 text-red-700 border border-red-200' :
       'bg-yellow-50 text-yellow-700 border border-yellow-200' %>">
    <% if (overallStatus === 'operational') { %>
      All Systems Operational
    <% } else if (overallStatus === 'major_outage') { %>
      Major Outage Detected
    <% } else { %>
      Some Systems Experiencing Issues
    <% } %>
  </div>

  <!-- Monitors -->
  <% if (monitors.length > 0) { %>
    <div class="space-y-4 mb-8">
      <% monitors.forEach(function(monitor) { %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full <%= monitor.status === 'up' ? 'bg-green-500' : monitor.status === 'down' ? 'bg-red-500 animate-pulse' : 'bg-gray-300' %>"></span>
              <span class="font-medium text-gray-800"><%= monitor.display_name || monitor.name %></span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <% if (monitor.stats && monitor.stats.uptime_30d) { %>
                <span class="text-gray-500"><%= monitor.stats.uptime_30d %>% uptime</span>
              <% } %>
              <span class="px-2 py-0.5 rounded text-xs font-medium
                <%= monitor.status === 'up' ? 'bg-green-100 text-green-700' :
                   monitor.status === 'down' ? 'bg-red-100 text-red-700' :
                   'bg-gray-100 text-gray-500' %>">
                <%= monitor.status === 'up' ? 'Operational' : monitor.status === 'down' ? 'Down' : 'Unknown' %>
              </span>
            </div>
          </div>

          <!-- 90-day uptime bar -->
          <% if (monitor.dailyUptime) { %>
            <div class="flex gap-px items-end" style="height: 28px;">
              <% monitor.dailyUptime.forEach(function(day) { %>
                <%
                  let color = 'bg-gray-200';
                  if (day.uptime !== null) {
                    if (day.uptime >= 99.9) color = 'bg-green-500';
                    else if (day.uptime >= 99) color = 'bg-green-400';
                    else if (day.uptime >= 95) color = 'bg-yellow-400';
                    else if (day.uptime >= 90) color = 'bg-orange-400';
                    else color = 'bg-red-500';
                  }
                %>
                <div class="<%= color %> rounded-sm flex-1" style="min-width: 2px; height: <%= day.uptime !== null ? Math.max(16, (day.uptime / 100) * 28) : 6 %>px;" title="<%= day.day %>: <%= day.uptime !== null ? day.uptime.toFixed(1) + '%' : 'No data' %>"></div>
              <% }); %>
            </div>
            <div class="flex justify-between text-xs text-gray-400 mt-1">
              <span>90 days ago</span>
              <span>Today</span>
            </div>
          <% } %>
        </div>
      <% }); %>
    </div>
  <% } %>

  <!-- Recent Incidents -->
  <% if (incidents.length > 0) { %>
    <div class="mb-8">
      <h2 class="text-lg font-semibold text-gray-700 mb-4">Recent Incidents</h2>
      <div class="space-y-3">
        <% incidents.forEach(function(incident) { %>
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
            <div class="flex items-center justify-between mb-1">
              <span class="font-medium text-gray-700"><%= incident.monitor_name %></span>
              <span class="text-xs px-2 py-0.5 rounded font-medium
                <%= incident.resolved_at ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                <%= incident.resolved_at ? 'Resolved' : 'Ongoing' %>
              </span>
            </div>
            <% if (incident.cause) { %>
              <p class="text-sm text-gray-500"><%= incident.cause %></p>
            <% } %>
            <p class="text-xs text-gray-400 mt-1">
              Started: <%= new Date(incident.started_at).toLocaleString() %>
              <% if (incident.resolved_at) { %>
                &middot; Resolved: <%= new Date(incident.resolved_at).toLocaleString() %>
              <% } %>
            </p>
          </div>
        <% }); %>
      </div>
    </div>
  <% } %>

  <!-- Footer -->
  <div class="text-center text-sm text-gray-400 mt-12">
    Powered by Uptime Monitor
    <br>
    <meta http-equiv="refresh" content="60">
  </div>
</div>
