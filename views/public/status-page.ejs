<div class="max-w-3xl mx-auto py-10 px-4 fade-in">
  <!-- Header -->
  <div class="text-center mb-10">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-slate-100 rounded-full text-xs font-medium text-slate-500 mb-4">
      <i data-lucide="activity" class="w-3.5 h-3.5"></i> System Status
    </div>
    <h1 class="text-3xl font-bold text-slate-800"><%= statusPage.title %></h1>
    <% if (statusPage.description) { %>
      <p class="text-slate-500 mt-2"><%= statusPage.description %></p>
    <% } %>
  </div>

  <!-- Overall status -->
  <div class="rounded-2xl p-5 mb-8 text-center font-semibold text-lg flex items-center justify-center gap-3
    <%= overallStatus === 'operational' ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' :
       overallStatus === 'major_outage' ? 'bg-red-50 text-red-700 border border-red-200' :
       'bg-amber-50 text-amber-700 border border-amber-200' %>">
    <% if (overallStatus === 'operational') { %>
      <i data-lucide="check-circle-2" class="w-6 h-6"></i> All Systems Operational
    <% } else if (overallStatus === 'major_outage') { %>
      <i data-lucide="alert-triangle" class="w-6 h-6"></i> Major Outage Detected
    <% } else { %>
      <i data-lucide="alert-circle" class="w-6 h-6"></i> Some Systems Experiencing Issues
    <% } %>
  </div>

  <!-- Monitors -->
  <% if (monitors.length > 0) { %>
    <div class="space-y-3 mb-10">
      <% monitors.forEach(function(monitor) { %>
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-5">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2.5">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center
                <%= monitor.status === 'up' ? 'bg-emerald-50' : monitor.status === 'down' ? 'bg-red-50' : 'bg-slate-100' %>">
                <% if (monitor.status === 'up') { %>
                  <i data-lucide="check" class="w-4 h-4 text-emerald-500"></i>
                <% } else if (monitor.status === 'down') { %>
                  <i data-lucide="x" class="w-4 h-4 text-red-500"></i>
                <% } else { %>
                  <i data-lucide="minus" class="w-4 h-4 text-slate-400"></i>
                <% } %>
              </div>
              <span class="font-medium text-slate-800"><%= monitor.display_name || monitor.name %></span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <% if (monitor.stats && monitor.stats.uptime_30d) { %>
                <span class="text-slate-400 font-medium"><%= monitor.stats.uptime_30d %>%</span>
              <% } %>
              <span class="px-2.5 py-1 rounded-lg text-xs font-semibold
                <%= monitor.status === 'up' ? 'bg-emerald-50 text-emerald-600' :
                   monitor.status === 'down' ? 'bg-red-50 text-red-600' :
                   'bg-slate-100 text-slate-500' %>">
                <%= monitor.status === 'up' ? 'Operational' : monitor.status === 'down' ? 'Down' : 'Unknown' %>
              </span>
            </div>
          </div>

          <% if (monitor.dailyUptime) { %>
            <div class="flex gap-[2px] items-end" style="height: 24px;">
              <% monitor.dailyUptime.forEach(function(day) { %>
                <%
                  let color = 'bg-slate-200';
                  if (day.uptime !== null) {
                    if (day.uptime >= 99.9) color = 'bg-emerald-500';
                    else if (day.uptime >= 99) color = 'bg-emerald-400';
                    else if (day.uptime >= 95) color = 'bg-amber-400';
                    else color = 'bg-red-500';
                  }
                %>
                <div class="<%= color %> rounded-[2px] flex-1" style="min-width: 2px; height: <%= day.uptime !== null ? Math.max(12, (day.uptime / 100) * 24) : 4 %>px;" title="<%= day.day %>: <%= day.uptime !== null ? day.uptime.toFixed(1) + '%' : 'No data' %>"></div>
              <% }); %>
            </div>
            <div class="flex justify-between text-[10px] text-slate-400 mt-1 font-medium">
              <span>90 days ago</span>
              <span>Today</span>
            </div>
          <% } %>
        </div>
      <% }); %>
    </div>
  <% } %>

  <!-- Recent Incidents -->
  <% if (incidents.length > 0) { %>
    <div class="mb-8">
      <h2 class="text-lg font-semibold text-slate-700 mb-4 flex items-center gap-2">
        <i data-lucide="alert-circle" class="w-5 h-5"></i> Recent Incidents
      </h2>
      <div class="space-y-3">
        <% incidents.forEach(function(incident) { %>
          <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4">
            <div class="flex items-center justify-between mb-1">
              <span class="font-medium text-slate-700 flex items-center gap-2">
                <i data-lucide="<%= incident.resolved_at ? 'check-circle-2' : 'alert-triangle' %>" class="w-4 h-4 <%= incident.resolved_at ? 'text-emerald-500' : 'text-red-500' %>"></i>
                <%= incident.monitor_name %>
              </span>
              <span class="text-xs px-2 py-0.5 rounded-lg font-medium
                <%= incident.resolved_at ? 'bg-emerald-50 text-emerald-600' : 'bg-red-50 text-red-600' %>">
                <%= incident.resolved_at ? 'Resolved' : 'Ongoing' %>
              </span>
            </div>
            <% if (incident.cause) { %>
              <p class="text-sm text-slate-500 ml-6"><%= incident.cause %></p>
            <% } %>
            <p class="text-xs text-slate-400 mt-1 ml-6">
              <%= new Date(incident.started_at).toLocaleString() %>
              <% if (incident.resolved_at) { %> &middot; Resolved: <%= new Date(incident.resolved_at).toLocaleString() %><% } %>
            </p>
          </div>
        <% }); %>
      </div>
    </div>
  <% } %>

  <!-- Footer -->
  <div class="text-center text-sm text-slate-400 mt-12 pb-8 flex items-center justify-center gap-2">
    <i data-lucide="activity" class="w-3.5 h-3.5"></i>
    Powered by Uptime Monitor
  </div>
  <meta http-equiv="refresh" content="60">
</div>
