<%# Expects: dailyUptime (array of { day, uptime }) %>
<div class="flex gap-[2px] items-end" style="height: 28px;" title="90-day uptime">
  <% if (typeof dailyUptime !== 'undefined' && dailyUptime) { %>
    <% dailyUptime.forEach(function(day) { %>
      <%
        let color = 'bg-slate-200';
        if (day.uptime !== null) {
          if (day.uptime >= 99.9) color = 'bg-emerald-500';
          else if (day.uptime >= 99) color = 'bg-emerald-400';
          else if (day.uptime >= 95) color = 'bg-amber-400';
          else if (day.uptime >= 90) color = 'bg-orange-400';
          else color = 'bg-red-500';
        }
      %>
      <div class="<%= color %> rounded-[2px] flex-1 transition-all hover:opacity-80" style="min-width: 2px; height: <%= day.uptime !== null ? Math.max(16, (day.uptime / 100) * 28) : 6 %>px;" title="<%= day.day %>: <%= day.uptime !== null ? day.uptime.toFixed(1) + '%' : 'No data' %>"></div>
    <% }); %>
  <% } %>
</div>
