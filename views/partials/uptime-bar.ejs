<%# Expects: dailyUptime (array of { day, uptime }) %>
<div class="flex gap-px items-end" style="height: 32px;" title="90-day uptime">
  <% if (typeof dailyUptime !== 'undefined' && dailyUptime) { %>
    <% dailyUptime.forEach(function(day) { %>
      <%
        let color = 'bg-gray-200'; // no data
        if (day.uptime !== null) {
          if (day.uptime >= 99.9) color = 'bg-green-500';
          else if (day.uptime >= 99) color = 'bg-green-400';
          else if (day.uptime >= 95) color = 'bg-yellow-400';
          else if (day.uptime >= 90) color = 'bg-orange-400';
          else color = 'bg-red-500';
        }
      %>
      <div class="<%= color %> rounded-sm flex-1" style="min-width: 3px; height: <%= day.uptime !== null ? Math.max(20, (day.uptime / 100) * 32) : 8 %>px;" title="<%= day.day %>: <%= day.uptime !== null ? day.uptime.toFixed(1) + '%' : 'No data' %>"></div>
    <% }); %>
  <% } %>
</div>
