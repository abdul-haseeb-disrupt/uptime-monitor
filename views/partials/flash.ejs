<% if (typeof flash !== 'undefined') { %>
  <% if (flash.success && flash.success.length > 0) { %>
    <div class="mx-6 mt-4 p-4 bg-green-50 border border-green-200 text-green-700 rounded-lg flex items-center gap-2" x-data="{ show: true }" x-show="show">
      <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
      <span><%= flash.success[0] %></span>
      <button @click="show = false" class="ml-auto text-green-500 hover:text-green-700">&times;</button>
    </div>
  <% } %>
  <% if (flash.error && flash.error.length > 0) { %>
    <div class="mx-6 mt-4 p-4 bg-red-50 border border-red-200 text-red-700 rounded-lg flex items-center gap-2" x-data="{ show: true }" x-show="show">
      <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
      <span><%= flash.error[0] %></span>
      <button @click="show = false" class="ml-auto text-red-500 hover:text-red-700">&times;</button>
    </div>
  <% } %>
  <% if (flash.info && flash.info.length > 0) { %>
    <div class="mx-6 mt-4 p-4 bg-blue-50 border border-blue-200 text-blue-700 rounded-lg flex items-center gap-2" x-data="{ show: true }" x-show="show">
      <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
      <span><%= flash.info[0] %></span>
      <button @click="show = false" class="ml-auto text-blue-500 hover:text-blue-700">&times;</button>
    </div>
  <% } %>
<% } %>
