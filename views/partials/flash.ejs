<% if (typeof flash !== 'undefined') { %>
  <% if ((flash.success && flash.success.length > 0) || (flash.error && flash.error.length > 0) || (flash.info && flash.info.length > 0)) { %>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        var notyf = new Notyf({
          duration: 4000,
          position: { x: 'right', y: 'top' },
          dismissible: true,
          ripple: true,
          types: [
            { type: 'info', background: '#6366f1', icon: false }
          ]
        });
        <% if (flash.success && flash.success.length > 0) { %>
          notyf.success('<%= flash.success[0].replace(/'/g, "\\'") %>');
        <% } %>
        <% if (flash.error && flash.error.length > 0) { %>
          notyf.error('<%= flash.error[0].replace(/'/g, "\\'") %>');
        <% } %>
        <% if (flash.info && flash.info.length > 0) { %>
          notyf.open({ type: 'info', message: '<%= flash.info[0].replace(/'/g, "\\'") %>' });
        <% } %>
      });
    </script>
  <% } %>
<% } %>
