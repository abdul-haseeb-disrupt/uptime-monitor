<aside class="fixed lg:relative inset-y-0 left-0 z-50 flex flex-col bg-dark-950 text-white transition-all duration-300"
  :class="mobileMenu ? 'translate-x-0 w-64' : '-translate-x-full lg:translate-x-0'"
  x-bind:style="sidebarOpen ? 'width: 256px' : 'width: 72px'">

  <!-- Logo -->
  <div class="p-4 border-b border-white/10 flex items-center gap-3 h-14">
    <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-primary-500 to-purple-600 flex items-center justify-center flex-shrink-0 shadow-lg shadow-primary-500/25">
      <i data-lucide="activity" class="w-5 h-5 text-white"></i>
    </div>
    <span class="text-base font-bold tracking-tight" x-show="sidebarOpen" x-transition>UptimeMonitor</span>
  </div>

  <nav class="flex-1 p-3 space-y-1 overflow-y-auto">
    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
      <div class="text-[10px] font-semibold text-slate-500 uppercase tracking-widest px-3 pt-3 pb-1" x-show="sidebarOpen">Admin</div>

      <a href="/admin" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium <%= typeof currentPath !== 'undefined' && currentPath === '/admin' ? 'bg-primary-600 text-white shadow-lg shadow-primary-600/25' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
        <i data-lucide="layout-grid" class="w-[18px] h-[18px] flex-shrink-0"></i>
        <span x-show="sidebarOpen">All Projects</span>
      </a>

      <a href="/admin/projects/new" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium <%= typeof currentPath !== 'undefined' && currentPath === '/admin/projects/new' ? 'bg-primary-600 text-white shadow-lg shadow-primary-600/25' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
        <i data-lucide="folder-plus" class="w-[18px] h-[18px] flex-shrink-0"></i>
        <span x-show="sidebarOpen">Add Project</span>
      </a>

      <a href="/admin/status" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium <%= typeof currentPath !== 'undefined' && currentPath === '/admin/status' ? 'bg-primary-600 text-white shadow-lg shadow-primary-600/25' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
        <i data-lucide="activity" class="w-[18px] h-[18px] flex-shrink-0"></i>
        <span x-show="sidebarOpen">Status Overview</span>
      </a>

      <a href="/admin/users" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium <%= typeof currentPath !== 'undefined' && currentPath.startsWith('/admin/users') ? 'bg-primary-600 text-white shadow-lg shadow-primary-600/25' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
        <i data-lucide="users" class="w-[18px] h-[18px] flex-shrink-0"></i>
        <span x-show="sidebarOpen">Users</span>
      </a>

      <div class="border-t border-white/5 my-3"></div>
      <div class="text-[10px] font-semibold text-slate-500 uppercase tracking-widest px-3 pt-1 pb-1" x-show="sidebarOpen">Tools</div>
    <% } else { %>
      <a href="/dashboard" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium <%= typeof currentPath !== 'undefined' && currentPath === '/dashboard' ? 'bg-primary-600 text-white shadow-lg shadow-primary-600/25' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
        <i data-lucide="home" class="w-[18px] h-[18px] flex-shrink-0"></i>
        <span x-show="sidebarOpen">Dashboard</span>
      </a>
    <% } %>

    <a href="/status-pages" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium <%= typeof currentPath !== 'undefined' && currentPath.startsWith('/status-pages') ? 'bg-primary-600 text-white shadow-lg shadow-primary-600/25' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
      <i data-lucide="globe" class="w-[18px] h-[18px] flex-shrink-0"></i>
      <span x-show="sidebarOpen">Status Pages</span>
    </a>

    <a href="/settings" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium <%= typeof currentPath !== 'undefined' && currentPath === '/settings' ? 'bg-primary-600 text-white shadow-lg shadow-primary-600/25' : 'text-slate-400 hover:text-white hover:bg-white/5' %>">
      <i data-lucide="settings" class="w-[18px] h-[18px] flex-shrink-0"></i>
      <span x-show="sidebarOpen">Settings</span>
    </a>
  </nav>

  <!-- Bottom -->
  <div class="p-3 border-t border-white/5">
    <div class="flex items-center gap-2 px-3 py-2 text-slate-500 text-xs" x-show="sidebarOpen">
      <i data-lucide="shield-check" class="w-3.5 h-3.5"></i>
      <span>Monitoring Active</span>
      <span class="ml-auto w-2 h-2 rounded-full bg-green-500 status-pulse"></span>
    </div>
  </div>
</aside>
