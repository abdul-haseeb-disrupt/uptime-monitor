<div x-data="{ refreshInterval: null }" x-init="refreshInterval = setInterval(() => location.reload(), 60000)" x-destroy="clearInterval(refreshInterval)">
  <!-- Stats Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
      <div class="text-sm text-gray-500 mb-1">Total Monitors</div>
      <div class="text-3xl font-bold text-gray-800"><%= stats.total %></div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
      <div class="text-sm text-gray-500 mb-1">Up</div>
      <div class="text-3xl font-bold text-green-600"><%= stats.up %></div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
      <div class="text-sm text-gray-500 mb-1">Down</div>
      <div class="text-3xl font-bold text-red-600"><%= stats.down %></div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
      <div class="text-sm text-gray-500 mb-1">Paused</div>
      <div class="text-3xl font-bold text-gray-400"><%= stats.paused %></div>
    </div>
  </div>

  <!-- Add Website Button -->
  <div class="flex justify-between items-center mb-6">
    <h2 class="text-lg font-semibold text-gray-700">Your Websites</h2>
    <a href="/websites/new" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      Add Website
    </a>
  </div>

  <% if (websites.length === 0) { %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center">
      <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
      <h3 class="text-lg font-medium text-gray-600 mb-2">No websites yet</h3>
      <p class="text-gray-400 mb-4">Add your first website to start monitoring</p>
      <a href="/websites/new" class="inline-flex items-center gap-2 bg-blue-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        Add Website
      </a>
    </div>
  <% } else { %>
    <!-- Website cards -->
    <div class="space-y-4">
      <% websites.forEach(function(website) { %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden" x-data="{ open: true }">
          <!-- Website header -->
          <div class="px-6 py-4 flex items-center justify-between cursor-pointer hover:bg-gray-50" @click="open = !open">
            <div class="flex items-center gap-3">
              <% if (website.down_count > 0) { %>
                <span class="w-3 h-3 rounded-full bg-red-500 animate-pulse"></span>
              <% } else if (parseInt(website.monitor_count) === 0) { %>
                <span class="w-3 h-3 rounded-full bg-gray-300"></span>
              <% } else { %>
                <span class="w-3 h-3 rounded-full bg-green-500"></span>
              <% } %>
              <div>
                <h3 class="font-semibold text-gray-800"><%= website.name %></h3>
                <% if (website.base_url) { %>
                  <p class="text-sm text-gray-400"><%= website.base_url %></p>
                <% } %>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <span class="text-sm text-gray-500">
                <span class="text-green-600 font-medium"><%= website.up_count %></span> up
                <% if (website.down_count > 0) { %>
                  / <span class="text-red-600 font-medium"><%= website.down_count %></span> down
                <% } %>
              </span>
              <svg class="w-5 h-5 text-gray-400 transition-transform" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </div>
          </div>

          <!-- Monitors list -->
          <div x-show="open" x-collapse>
            <div class="border-t border-gray-100">
              <% const monitors = websiteMonitors[website.id] || []; %>
              <% if (monitors.length === 0) { %>
                <div class="px-6 py-4 text-center text-gray-400 text-sm">
                  No monitors yet.
                  <a href="/monitors/new?website_id=<%= website.id %>" class="text-blue-600 hover:underline">Add one</a>
                </div>
              <% } else { %>
                <% monitors.forEach(function(monitor) { %>
                  <a href="/monitors/<%= monitor.id %>" class="flex items-center justify-between px-6 py-3 hover:bg-gray-50 border-b border-gray-50 last:border-0">
                    <div class="flex items-center gap-3">
                      <% if (monitor.status === 'up') { %>
                        <span class="w-2.5 h-2.5 rounded-full bg-green-500"></span>
                      <% } else if (monitor.status === 'down') { %>
                        <span class="w-2.5 h-2.5 rounded-full bg-red-500 animate-pulse"></span>
                      <% } else if (monitor.status === 'paused') { %>
                        <span class="w-2.5 h-2.5 rounded-full bg-gray-300"></span>
                      <% } else { %>
                        <span class="w-2.5 h-2.5 rounded-full bg-yellow-400"></span>
                      <% } %>
                      <div>
                        <span class="text-sm font-medium text-gray-700"><%= monitor.name %></span>
                        <span class="text-xs text-gray-400 ml-2 uppercase"><%= monitor.type %></span>
                      </div>
                    </div>
                    <div class="flex items-center gap-4 text-sm">
                      <% if (monitor.last_checked_at) { %>
                        <span class="text-gray-400"><%= timeAgo(monitor.last_checked_at) %></span>
                      <% } %>
                      <span class="px-2 py-0.5 rounded text-xs font-medium
                        <%= monitor.status === 'up' ? 'bg-green-100 text-green-700' :
                           monitor.status === 'down' ? 'bg-red-100 text-red-700' :
                           monitor.status === 'paused' ? 'bg-gray-100 text-gray-500' :
                           'bg-yellow-100 text-yellow-700' %>">
                        <%= monitor.status.toUpperCase() %>
                      </span>
                    </div>
                  </a>
                <% }); %>
              <% } %>
              <!-- Add monitor link -->
              <div class="px-6 py-2 bg-gray-50 border-t border-gray-100">
                <a href="/monitors/new?website_id=<%= website.id %>" class="text-sm text-blue-600 hover:underline flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
                  Add Monitor
                </a>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>
