<div class="min-h-screen flex items-center justify-center">
  <div class="text-center">
    <h1 class="text-6xl font-bold text-gray-300 mb-4"><%= typeof title !== 'undefined' ? title : 'Error' %></h1>
    <p class="text-xl text-gray-500 mb-8"><%= typeof message !== 'undefined' ? message : 'Something went wrong' %></p>
    <a href="/" class="bg-blue-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700">Go Home</a>
  </div>
</div>
