<div class="min-h-screen flex items-center justify-center fade-in">
  <div class="text-center">
    <div class="w-20 h-20 rounded-3xl bg-slate-100 flex items-center justify-center mx-auto mb-6">
      <i data-lucide="alert-triangle" class="w-10 h-10 text-slate-400"></i>
    </div>
    <h1 class="text-5xl font-bold text-slate-300 mb-3"><%= typeof title !== 'undefined' ? title : 'Error' %></h1>
    <p class="text-lg text-slate-500 mb-8"><%= typeof message !== 'undefined' ? message : 'Something went wrong' %></p>
    <a href="/" class="inline-flex items-center gap-2 bg-gradient-to-r from-primary-600 to-primary-700 text-white px-6 py-2.5 rounded-xl font-medium shadow-lg shadow-primary-500/25">
      <i data-lucide="home" class="w-4 h-4"></i> Go Home
    </a>
  </div>
</div>
