<div class="fade-in">
  <!-- Overview Stats -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-5 card-hover">
      <div class="flex items-center justify-between mb-3">
        <div class="w-10 h-10 rounded-xl bg-primary-50 flex items-center justify-center">
          <i data-lucide="folder" class="w-5 h-5 text-primary-600"></i>
        </div>
      </div>
      <div class="text-2xl font-bold text-slate-800"><%= overall.total_projects || 0 %></div>
      <div class="text-sm text-slate-500 mt-0.5">Total Projects</div>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-5 card-hover">
      <div class="flex items-center justify-between mb-3">
        <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center">
          <i data-lucide="file-text" class="w-5 h-5 text-blue-600"></i>
        </div>
      </div>
      <div class="text-2xl font-bold text-slate-800"><%= overall.total_monitors || 0 %></div>
      <div class="text-sm text-slate-500 mt-0.5">Total Pages</div>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-5 card-hover">
      <div class="flex items-center justify-between mb-3">
        <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center">
          <i data-lucide="check-circle-2" class="w-5 h-5 text-green-600"></i>
        </div>
        <span class="text-xs font-medium px-2 py-1 rounded-full bg-green-50 text-green-600"><%= overall.up_count || 0 %> up</span>
      </div>
      <div class="text-2xl font-bold text-green-600"><%= overall.total_monitors > 0 ? Math.round(((overall.up_count || 0) / overall.total_monitors) * 100) : 0 %>%</div>
      <div class="text-sm text-slate-500 mt-0.5">Healthy</div>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-5 card-hover">
      <div class="flex items-center justify-between mb-3">
        <div class="w-10 h-10 rounded-xl <%= parseInt(overall.down_count) > 0 ? 'bg-red-50' : 'bg-slate-50' %> flex items-center justify-center">
          <i data-lucide="<%= parseInt(overall.down_count) > 0 ? 'alert-triangle' : 'shield-check' %>" class="w-5 h-5 <%= parseInt(overall.down_count) > 0 ? 'text-red-600' : 'text-slate-400' %>"></i>
        </div>
        <% if (parseInt(overall.down_count) > 0) { %>
          <span class="text-xs font-medium px-2 py-1 rounded-full bg-red-50 text-red-600 status-pulse"><%= overall.down_count %> down</span>
        <% } %>
      </div>
      <div class="text-2xl font-bold <%= parseInt(overall.down_count) > 0 ? 'text-red-600' : 'text-slate-800' %>"><%= parseInt(overall.down_count) > 0 ? overall.down_count : 'None' %></div>
      <div class="text-sm text-slate-500 mt-0.5">Issues</div>
    </div>
  </div>

  <!-- Actions -->
  <div class="flex justify-between items-center mb-5">
    <h2 class="text-base font-semibold text-slate-700">All Projects</h2>
    <a href="/admin/projects/new" class="bg-gradient-to-r from-primary-600 to-primary-700 text-white px-4 py-2 rounded-xl text-sm font-medium hover:from-primary-700 hover:to-primary-800 transition-all shadow-sm shadow-primary-500/25 flex items-center gap-2">
      <i data-lucide="plus" class="w-4 h-4"></i> Add Project
    </a>
  </div>

  <% if (websites.length === 0) { %>
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-16 text-center">
      <div class="w-16 h-16 rounded-2xl bg-slate-100 flex items-center justify-center mx-auto mb-4">
        <i data-lucide="globe" class="w-8 h-8 text-slate-300"></i>
      </div>
      <h3 class="text-lg font-semibold text-slate-600 mb-2">No projects yet</h3>
      <p class="text-slate-400 mb-6">Create your first project to start monitoring</p>
      <a href="/admin/projects/new" class="inline-flex items-center gap-2 bg-gradient-to-r from-primary-600 to-primary-700 text-white px-6 py-2.5 rounded-xl font-medium shadow-lg shadow-primary-500/25">
        <i data-lucide="plus" class="w-4 h-4"></i> Add Project
      </a>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
      <% websites.forEach(function(website) { %>
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 card-hover group relative">
          <a href="/admin/projects/<%= website.id %>" class="block p-5">
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl <%= parseInt(website.down_count) > 0 ? 'bg-red-50' : parseInt(website.monitor_count) === 0 ? 'bg-slate-100' : 'bg-green-50' %> flex items-center justify-center flex-shrink-0">
                  <% if (parseInt(website.down_count) > 0) { %>
                    <i data-lucide="alert-circle" class="w-5 h-5 text-red-500"></i>
                  <% } else if (parseInt(website.monitor_count) === 0) { %>
                    <i data-lucide="globe" class="w-5 h-5 text-slate-400"></i>
                  <% } else { %>
                    <i data-lucide="check-circle-2" class="w-5 h-5 text-green-500"></i>
                  <% } %>
                </div>
                <div>
                  <h3 class="font-semibold text-slate-800 group-hover:text-primary-600 transition-colors"><%= website.name %></h3>
                  <% if (website.base_url) { %>
                    <p class="text-xs text-slate-400 truncate max-w-[180px]"><%= website.base_url %></p>
                  <% } %>
                </div>
              </div>
              <i data-lucide="chevron-right" class="w-4 h-4 text-slate-300 group-hover:text-primary-400 transition-colors"></i>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs font-medium px-2 py-1 rounded-lg bg-slate-100 text-slate-600"><%= website.monitor_count %> pages</span>
              <% if (parseInt(website.up_count) > 0) { %>
                <span class="text-xs font-medium px-2 py-1 rounded-lg bg-green-50 text-green-600"><%= website.up_count %> up</span>
              <% } %>
              <% if (parseInt(website.down_count) > 0) { %>
                <span class="text-xs font-medium px-2 py-1 rounded-lg bg-red-50 text-red-600 status-pulse"><%= website.down_count %> down</span>
              <% } %>
            </div>
          </a>
          <a href="/admin/projects/<%= website.id %>/edit" class="absolute top-4 right-4 p-1.5 rounded-lg border border-slate-200 text-slate-400 hover:text-primary-600 hover:border-primary-200 hover:bg-primary-50 transition-colors opacity-0 group-hover:opacity-100 z-10" title="Edit">
            <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
          </a>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>
