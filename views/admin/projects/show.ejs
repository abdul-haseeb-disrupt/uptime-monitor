<div class="fade-in">
  <!-- Breadcrumb + Actions -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <div class="flex items-center gap-2 text-sm text-slate-400 mb-1">
        <a href="/admin" class="hover:text-primary-600 transition-colors">All Projects</a>
        <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
        <span class="text-slate-600 font-medium"><%= website.name %></span>
      </div>
      <% if (website.base_url) { %>
        <p class="text-sm text-slate-400 flex items-center gap-1.5">
          <i data-lucide="link" class="w-3.5 h-3.5"></i> <%= website.base_url %>
        </p>
      <% } %>
    </div>
    <div class="flex gap-2">
      <a href="/admin/projects/<%= website.id %>/pages/new" class="bg-gradient-to-r from-primary-600 to-primary-700 text-white px-4 py-2 rounded-xl text-sm font-medium hover:from-primary-700 hover:to-primary-800 shadow-sm shadow-primary-500/25 flex items-center gap-2 transition-all">
        <i data-lucide="plus" class="w-4 h-4"></i> Add Page
      </a>
      <a href="/admin/projects/<%= website.id %>/edit" class="px-3 py-2 rounded-xl text-sm font-medium text-slate-600 hover:bg-slate-100 border border-slate-200 transition-colors">
        <i data-lucide="pencil" class="w-4 h-4"></i>
      </a>
      <form action="/admin/projects/<%= website.id %>/delete" method="POST" onsubmit="return confirm('Delete this project and ALL its pages?')" class="inline">
        <button type="submit" class="px-3 py-2 rounded-xl text-sm font-medium text-red-500 hover:bg-red-50 border border-red-200 transition-colors">
          <i data-lucide="trash-2" class="w-4 h-4"></i>
        </button>
      </form>
    </div>
  </div>

  <!-- Assigned Users -->
  <% if (assignedUsers.length > 0) { %>
    <div class="bg-primary-50 border border-primary-200 rounded-xl p-3 mb-6 flex items-center gap-2">
      <i data-lucide="users" class="w-4 h-4 text-primary-600 flex-shrink-0"></i>
      <span class="text-sm text-primary-700">Assigned to: <strong><%= assignedUsers.map(u => u.name).join(', ') %></strong></span>
    </div>
  <% } %>

  <!-- Pages List -->
  <% if (monitors.length === 0) { %>
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-16 text-center">
      <div class="w-16 h-16 rounded-2xl bg-slate-100 flex items-center justify-center mx-auto mb-4">
        <i data-lucide="file-plus" class="w-8 h-8 text-slate-300"></i>
      </div>
      <h3 class="text-lg font-semibold text-slate-600 mb-2">No pages added yet</h3>
      <p class="text-slate-400 mb-6">Add pages to monitor for this project</p>
      <a href="/admin/projects/<%= website.id %>/pages/new" class="inline-flex items-center gap-2 bg-gradient-to-r from-primary-600 to-primary-700 text-white px-6 py-2.5 rounded-xl font-medium shadow-lg shadow-primary-500/25">
        <i data-lucide="plus" class="w-4 h-4"></i> Add Page
      </a>
    </div>
  <% } else { %>
    <div class="space-y-3">
      <% monitors.forEach(function(monitor) { %>
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-5 card-hover">
          <!-- Header -->
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0
                <%= monitor.status === 'up' ? 'bg-emerald-50' : monitor.status === 'down' ? 'bg-red-50' : monitor.status === 'paused' ? 'bg-slate-100' : 'bg-amber-50' %>">
                <% if (monitor.status === 'up') { %>
                  <i data-lucide="check-circle-2" class="w-5 h-5 text-emerald-500"></i>
                <% } else if (monitor.status === 'down') { %>
                  <i data-lucide="x-circle" class="w-5 h-5 text-red-500 status-pulse"></i>
                <% } else if (monitor.status === 'paused') { %>
                  <i data-lucide="pause-circle" class="w-5 h-5 text-slate-400"></i>
                <% } else { %>
                  <i data-lucide="help-circle" class="w-5 h-5 text-amber-500"></i>
                <% } %>
              </div>
              <div>
                <div class="flex items-center gap-2">
                  <span class="font-semibold text-slate-800"><%= monitor.name %></span>
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded-md bg-slate-100 text-slate-500 uppercase"><%= monitor.type %></span>
                </div>
                <div class="text-xs text-slate-400 mt-0.5 truncate max-w-md">
                  <% if (monitor.url) { %><%= monitor.url %><% } %>
                  <% if (monitor.hostname) { %><%= monitor.hostname %><% if (monitor.port) { %>:<%= monitor.port %><% } %><% } %>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-1.5">
              <form action="/admin/projects/<%= website.id %>/pages/<%= monitor.id %>/toggle" method="POST" class="inline">
                <button type="submit" class="p-1.5 rounded-lg border transition-colors <%= monitor.is_active ? 'text-amber-500 border-amber-200 hover:bg-amber-50' : 'text-emerald-500 border-emerald-200 hover:bg-emerald-50' %>" title="<%= monitor.is_active ? 'Pause' : 'Resume' %>">
                  <i data-lucide="<%= monitor.is_active ? 'pause' : 'play' %>" class="w-3.5 h-3.5"></i>
                </button>
              </form>
              <form action="/admin/projects/<%= website.id %>/pages/<%= monitor.id %>/delete" method="POST" onsubmit="return confirm('Delete this page?')" class="inline">
                <button type="submit" class="p-1.5 rounded-lg border text-red-400 border-red-200 hover:bg-red-50 transition-colors" title="Delete">
                  <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                </button>
              </form>
            </div>
          </div>

          <!-- Stats row -->
          <div class="grid grid-cols-4 gap-2 mb-3">
            <% ['24h', '7d', '30d'].forEach(function(period) { %>
              <div class="text-center p-2 rounded-lg bg-slate-50">
                <div class="text-[10px] font-medium text-slate-400 uppercase"><%= period %></div>
                <% var val = monitor.stats ? monitor.stats['uptime_' + period] : null; %>
                <div class="text-sm font-bold mt-0.5 <%= val && val >= 99 ? 'text-emerald-600' : val && val < 99 ? 'text-red-600' : 'text-slate-400' %>"><%= val ? val + '%' : 'N/A' %></div>
              </div>
            <% }); %>
            <div class="text-center p-2 rounded-lg bg-slate-50">
              <div class="text-[10px] font-medium text-slate-400 uppercase">Resp</div>
              <div class="text-sm font-bold mt-0.5 text-slate-600"><%= monitor.stats && monitor.stats.avg_response_24h ? monitor.stats.avg_response_24h + 'ms' : 'N/A' %></div>
            </div>
          </div>

          <!-- PageSpeed scores (Mobile + Desktop) -->
          <% if (monitor.pagespeed) { %>
            <% ['mobile', 'desktop'].forEach(function(strategy) { %>
              <% var ps = monitor.pagespeed[strategy]; %>
              <% if (ps) { %>
                <div class="mb-2">
                  <div class="text-[10px] font-semibold text-slate-400 uppercase mb-1.5 flex items-center gap-1">
                    <i data-lucide="<%= strategy === 'mobile' ? 'smartphone' : 'monitor' %>" class="w-3 h-3"></i> <%= strategy %>
                  </div>
                  <div class="grid grid-cols-4 gap-2">
                    <% [
                      { label: 'Perf', val: ps.performance },
                      { label: 'A11y', val: ps.accessibility },
                      { label: 'BP', val: ps.best_practices },
                      { label: 'SEO', val: ps.seo }
                    ].forEach(function(item) { %>
                      <div class="text-center p-1.5 rounded-lg border
                        <%= item.val >= 90 ? 'bg-emerald-50 border-emerald-200' : item.val >= 50 ? 'bg-amber-50 border-amber-200' : 'bg-red-50 border-red-200' %>">
                        <div class="text-[9px] font-medium text-slate-500 uppercase"><%= item.label %></div>
                        <div class="text-base font-bold <%= item.val >= 90 ? 'text-emerald-600' : item.val >= 50 ? 'text-amber-600' : 'text-red-600' %>"><%= item.val %></div>
                      </div>
                    <% }); %>
                  </div>
                  <div class="flex items-center gap-3 text-[10px] text-slate-400 mt-1 px-1">
                    <% if (ps.lcp) { %><span>LCP: <strong class="<%= ps.lcp <= 2.5 ? 'text-emerald-600' : ps.lcp <= 4 ? 'text-amber-600' : 'text-red-600' %>"><%= ps.lcp %>s</strong></span><% } %>
                    <% if (ps.cls !== null && ps.cls !== undefined) { %><span>CLS: <strong class="<%= ps.cls <= 0.1 ? 'text-emerald-600' : ps.cls <= 0.25 ? 'text-amber-600' : 'text-red-600' %>"><%= ps.cls %></strong></span><% } %>
                    <% if (ps.fcp) { %><span>FCP: <strong><%= ps.fcp %>ms</strong></span><% } %>
                    <% if (ps.ttfb) { %><span>TTFB: <strong><%= ps.ttfb %>ms</strong></span><% } %>
                  </div>
                </div>
              <% } %>
            <% }); %>
          <% } %>

          <!-- Uptime bar -->
          <%- include('../../partials/uptime-bar', { dailyUptime: monitor.dailyUptime }) %>

          <% if (monitor.lastCheck) { %>
            <div class="flex items-center gap-1.5 text-xs text-slate-400 mt-2">
              <i data-lucide="clock" class="w-3 h-3"></i>
              Last checked: <%= timeAgo(monitor.lastCheck.checked_at) %> &middot; <%= formatResponseTime(monitor.lastCheck.response_time) %>
            </div>
          <% } %>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>
