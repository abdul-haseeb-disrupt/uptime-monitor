<div class="fade-in" x-data="{ device: 'desktop', period: '24h', openRow: null }">
  <!-- Breadcrumb + Actions -->
  <div class="flex items-center justify-between mb-5">
    <div>
      <div class="flex items-center gap-2 text-sm text-slate-400 mb-1">
        <a href="/admin" class="hover:text-primary-600 transition-colors">All Projects</a>
        <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
        <span class="text-slate-600 font-medium"><%= website.name %></span>
      </div>
      <% if (website.base_url) { %>
        <p class="text-sm text-slate-400 flex items-center gap-1.5">
          <i data-lucide="link" class="w-3.5 h-3.5"></i> <%= website.base_url %>
        </p>
      <% } %>
    </div>
    <div class="flex gap-2">
      <form action="/admin/projects/<%= website.id %>/run-pagespeed" method="POST" class="inline">
        <button type="submit" class="px-3 py-2 rounded-xl text-sm font-medium text-primary-600 border border-primary-200 hover:bg-primary-50 transition-colors flex items-center gap-1.5">
          <i data-lucide="gauge" class="w-4 h-4"></i> Run PageSpeed
        </button>
      </form>
      <% if (website.sitemaps && website.sitemaps.length > 0) { %>
        <form action="/admin/projects/<%= website.id %>/sync-sitemap" method="POST" class="inline">
          <button type="submit" class="px-3 py-2 rounded-xl text-sm font-medium text-slate-600 border border-slate-200 hover:bg-slate-50 transition-colors flex items-center gap-1.5">
            <i data-lucide="refresh-cw" class="w-4 h-4"></i> Sync Sitemap
          </button>
        </form>
      <% } %>
      <a href="/admin/projects/<%= website.id %>/pages/new" class="bg-gradient-to-r from-primary-600 to-primary-700 text-white px-4 py-2 rounded-xl text-sm font-medium hover:from-primary-700 hover:to-primary-800 shadow-sm shadow-primary-500/25 flex items-center gap-2">
        <i data-lucide="plus" class="w-4 h-4"></i> Add Page
      </a>
      <a href="/admin/projects/<%= website.id %>/edit" class="px-3 py-2 rounded-xl text-sm font-medium text-slate-600 hover:bg-slate-100 border border-slate-200">
        <i data-lucide="pencil" class="w-4 h-4"></i>
      </a>
      <form action="/admin/projects/<%= website.id %>/delete" method="POST" onsubmit="return confirm('Delete this project and ALL its pages?')" class="inline">
        <button type="submit" class="px-3 py-2 rounded-xl text-sm font-medium text-red-500 hover:bg-red-50 border border-red-200">
          <i data-lucide="trash-2" class="w-4 h-4"></i>
        </button>
      </form>
    </div>
  </div>

  <% if (assignedUsers.length > 0) { %>
    <div class="bg-primary-50 border border-primary-200 rounded-xl p-3 mb-4 flex items-center gap-2">
      <i data-lucide="users" class="w-4 h-4 text-primary-600 flex-shrink-0"></i>
      <span class="text-sm text-primary-700">Assigned to: <strong><%= assignedUsers.map(u => u.name).join(', ') %></strong></span>
    </div>
  <% } %>

  <% if (monitors.length === 0) { %>
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-16 text-center">
      <div class="w-16 h-16 rounded-2xl bg-slate-100 flex items-center justify-center mx-auto mb-4">
        <i data-lucide="file-plus" class="w-8 h-8 text-slate-300"></i>
      </div>
      <h3 class="text-lg font-semibold text-slate-600 mb-2">No pages added yet</h3>
      <p class="text-slate-400 mb-6">Add pages to monitor for this project</p>
      <a href="/admin/projects/<%= website.id %>/pages/new" class="inline-flex items-center gap-2 bg-gradient-to-r from-primary-600 to-primary-700 text-white px-6 py-2.5 rounded-xl font-medium shadow-lg shadow-primary-500/25">
        <i data-lucide="plus" class="w-4 h-4"></i> Add Page
      </a>
    </div>
  <% } else { %>

    <!-- Filters Row -->
    <div class="flex items-center justify-between mb-3 flex-wrap gap-3">
      <div class="flex items-center gap-3">
        <span class="text-sm text-slate-500"><%= monitors.length %> pages</span>
        <div class="inline-flex items-center bg-slate-100 rounded-lg p-0.5">
          <% ['24h', '7d', '30d', '90d'].forEach(function(r) { %>
            <button @click="period = '<%= r %>'"
              :class="period === '<%= r %>' ? 'bg-white shadow-sm text-slate-800' : 'text-slate-500 hover:text-slate-700'"
              class="px-2.5 py-1 rounded-md text-[11px] font-semibold transition-all"><%= r === '24h' ? '24 Hours' : r === '7d' ? '7 Days' : r === '30d' ? '30 Days' : '90 Days' %></button>
          <% }); %>
        </div>
      </div>
      <div class="inline-flex items-center bg-slate-100 rounded-lg p-0.5">
        <button @click="device = 'desktop'"
          :class="device === 'desktop' ? 'bg-white shadow-sm text-slate-800' : 'text-slate-500 hover:text-slate-700'"
          class="flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[11px] font-semibold transition-all">
          <i data-lucide="monitor" class="w-3.5 h-3.5"></i> Desktop
        </button>
        <button @click="device = 'mobile'"
          :class="device === 'mobile' ? 'bg-white shadow-sm text-slate-800' : 'text-slate-500 hover:text-slate-700'"
          class="flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[11px] font-semibold transition-all">
          <i data-lucide="smartphone" class="w-3.5 h-3.5"></i> Mobile
        </button>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-600 w-5"></th>
              <th class="text-left px-2 py-3 text-xs font-semibold text-slate-600">Page</th>
              <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">Uptime</th>
              <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">Response</th>
              <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">Performance</th>
              <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">Accessibility</th>
              <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">Best Practices</th>
              <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">SEO</th>
              <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">LCP</th>
              <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">CLS</th>
              <th class="text-right px-3 py-3 text-xs font-semibold text-slate-600">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% monitors.forEach(function(monitor, index) { %>
              <%
                var ps = null;
                if (monitor.pagespeed && monitor.pagespeed['24h']) {
                  ps = monitor.pagespeed['24h'];
                }
                // Build all uptime data for Alpine
                var uptimeBarData = {};
                ['24h', '7', '30', '90'].forEach(function(p) {
                  uptimeBarData[p] = monitor.uptimeData[p] || [];
                });
              %>
              <tr class="<%= index < monitors.length - 1 ? 'border-b border-slate-100' : '' %> hover:bg-slate-50/50 transition-colors cursor-pointer"
                @click="openRow = openRow === <%= monitor.id %> ? null : <%= monitor.id %>"
                x-data='{
                  ps: <%= JSON.stringify({
                    mobile: ps && ps.mobile ? { performance: parseInt(ps.mobile.performance)||null, accessibility: parseInt(ps.mobile.accessibility)||null, best_practices: parseInt(ps.mobile.best_practices)||null, seo: parseInt(ps.mobile.seo)||null, lcp: ps.mobile.lcp?parseFloat(ps.mobile.lcp):null, cls: ps.mobile.cls!==null?parseFloat(ps.mobile.cls):null } : null,
                    desktop: ps && ps.desktop ? { performance: parseInt(ps.desktop.performance)||null, accessibility: parseInt(ps.desktop.accessibility)||null, best_practices: parseInt(ps.desktop.best_practices)||null, seo: parseInt(ps.desktop.seo)||null, lcp: ps.desktop.lcp?parseFloat(ps.desktop.lcp):null, cls: ps.desktop.cls!==null?parseFloat(ps.desktop.cls):null } : null
                  }) %>,
                  stats: <%= JSON.stringify({
                    uptime_24h: monitor.stats ? monitor.stats.uptime_24h : null,
                    uptime_7d: monitor.stats ? monitor.stats.uptime_7d : null,
                    uptime_30d: monitor.stats ? monitor.stats.uptime_30d : null,
                    uptime_90d: monitor.stats ? monitor.stats.uptime_90d : null
                  }) %>,
                  g(f) { let d = this.ps[device]; return d ? d[f] : null; },
                  sc(v) { if(!v&&v!==0) return "text-slate-300"; if(v>=90) return "text-emerald-600 bg-emerald-50"; if(v>=50) return "text-amber-600 bg-amber-50"; return "text-red-600 bg-red-50"; },
                  lc(v) { if(!v) return "text-slate-300"; if(v<=2.5) return "text-emerald-600"; if(v<=4) return "text-amber-600"; return "text-red-600"; },
                  cc(v) { if(v===null||v===undefined) return "text-slate-300"; if(v<=0.1) return "text-emerald-600"; if(v<=0.25) return "text-amber-600"; return "text-red-600"; }
                }'>
                <!-- Expand icon -->
                <td class="pl-4 pr-1 py-2.5">
                  <i data-lucide="chevron-right" class="w-3.5 h-3.5 text-slate-400 transition-transform" :class="openRow === <%= monitor.id %> ? 'rotate-90' : ''"></i>
                </td>

                <!-- Page name -->
                <td class="px-2 py-2.5">
                  <div class="flex items-center gap-2 min-w-0">
                    <span class="w-2 h-2 rounded-full flex-shrink-0
                      <%= monitor.status === 'up' ? 'bg-emerald-500' : monitor.status === 'down' ? 'bg-red-500 status-pulse' : monitor.status === 'paused' ? 'bg-slate-300' : 'bg-amber-400' %>"></span>
                    <div class="min-w-0">
                      <div class="text-sm font-medium text-slate-700 truncate max-w-[180px]"><%= monitor.name %></div>
                      <div class="text-[10px] text-slate-400 truncate max-w-[180px]">
                        <% if (monitor.url) { %><%= monitor.url.replace(/^https?:\/\//, '') %><% } %>
                        <% if (monitor.hostname) { %><%= monitor.hostname %><% if (monitor.port) { %>:<%= monitor.port %><% } %><% } %>
                      </div>
                    </div>
                  </div>
                </td>

                <!-- Uptime (dynamic) -->
                <td class="px-2 py-2.5 text-center">
                  <span class="text-xs font-bold"
                    :class="{ 'text-emerald-600': stats['uptime_' + period] >= 99, 'text-red-600': stats['uptime_' + period] && stats['uptime_' + period] < 99, 'text-slate-400': !stats['uptime_' + period] }"
                    x-text="stats['uptime_' + period] ? stats['uptime_' + period] + '%' : '-'"></span>
                </td>

                <!-- Response -->
                <td class="px-2 py-2.5 text-center">
                  <span class="text-xs font-bold text-slate-600"><%= monitor.stats && monitor.stats.avg_response_24h ? monitor.stats.avg_response_24h + 'ms' : '-' %></span>
                </td>

                <!-- PageSpeed (dynamic) -->
                <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold px-1.5 py-0.5 rounded" :class="sc(g('performance'))" x-text="g('performance') !== null ? g('performance') : '-'"></span></td>
                <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold px-1.5 py-0.5 rounded" :class="sc(g('accessibility'))" x-text="g('accessibility') !== null ? g('accessibility') : '-'"></span></td>
                <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold px-1.5 py-0.5 rounded" :class="sc(g('best_practices'))" x-text="g('best_practices') !== null ? g('best_practices') : '-'"></span></td>
                <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold px-1.5 py-0.5 rounded" :class="sc(g('seo'))" x-text="g('seo') !== null ? g('seo') : '-'"></span></td>
                <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold" :class="lc(g('lcp'))" x-text="g('lcp') !== null ? g('lcp') + 's' : '-'"></span></td>
                <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold" :class="cc(g('cls'))" x-text="g('cls') !== null ? g('cls') : '-'"></span></td>

                <!-- Actions -->
                <td class="px-3 py-2.5 text-right" @click.stop>
                  <div class="flex items-center justify-end gap-1">
                    <form action="/admin/projects/<%= website.id %>/pages/<%= monitor.id %>/toggle" method="POST" class="inline">
                      <button type="submit" class="p-1 rounded-lg border transition-colors <%= monitor.is_active ? 'text-amber-500 border-amber-200 hover:bg-amber-50' : 'text-emerald-500 border-emerald-200 hover:bg-emerald-50' %>" title="<%= monitor.is_active ? 'Pause' : 'Resume' %>">
                        <i data-lucide="<%= monitor.is_active ? 'pause' : 'play' %>" class="w-3 h-3"></i>
                      </button>
                    </form>
                    <form action="/admin/projects/<%= website.id %>/pages/<%= monitor.id %>/delete" method="POST" onsubmit="return confirm('Delete?')" class="inline">
                      <button type="submit" class="p-1 rounded-lg border text-red-400 border-red-200 hover:bg-red-50 transition-colors" title="Delete">
                        <i data-lucide="trash-2" class="w-3 h-3"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>

              <!-- Drawer - Uptime Bar Graph -->
              <tr x-show="openRow === <%= monitor.id %>" x-collapse x-cloak class="border-b border-slate-100">
                <td colspan="11" class="px-4 py-4 bg-slate-50/50">
                  <div class="flex items-center gap-2 mb-2">
                    <i data-lucide="bar-chart-3" class="w-4 h-4 text-slate-400"></i>
                    <span class="text-xs font-semibold text-slate-500" x-text="period === '24h' ? 'Hourly Uptime (Last 24 Hours)' : period === '7d' ? 'Daily Uptime (Last 7 Days)' : period === '30d' ? 'Daily Uptime (Last 30 Days)' : 'Daily Uptime (Last 90 Days)'"></span>
                    <% if (monitor.lastCheck) { %>
                      <span class="text-[10px] text-slate-400 ml-auto flex items-center gap-1">
                        <i data-lucide="clock" class="w-3 h-3"></i>
                        Last checked: <%= timeAgo(monitor.lastCheck.checked_at) %> &middot; <%= formatResponseTime(monitor.lastCheck.response_time) %>
                      </span>
                    <% } %>
                  </div>
                  <!-- Bar graphs for each period -->
                  <% ['24h', '7', '30', '90'].forEach(function(p) { %>
                    <div x-show="period === '<%= p === '24h' ? '24h' : p + 'd' %>'" class="flex gap-[2px] items-end h-10 w-full">
                      <% (monitor.uptimeData[p] || []).forEach(function(day) { %>
                        <%
                          let c = 'bg-slate-200';
                          if (day.uptime !== null) {
                            if (day.uptime >= 99.9) c = 'bg-emerald-500';
                            else if (day.uptime >= 99) c = 'bg-emerald-400';
                            else if (day.uptime >= 95) c = 'bg-amber-400';
                            else c = 'bg-red-500';
                          }
                        %>
                        <div class="<%= c %> rounded-[2px] flex-1 hover:opacity-75 transition-opacity" style="min-width:2px; height:<%= day.uptime !== null ? Math.max(8, (day.uptime/100)*40) : 4 %>px;" title="<%= day.day %>: <%= day.uptime !== null ? day.uptime.toFixed(1)+'%' : 'No data' %>"></div>
                      <% }); %>
                    </div>
                  <% }); %>
                  <div class="flex justify-between text-[10px] text-slate-400 mt-1">
                    <span x-text="period === '24h' ? '24h ago' : period === '7d' ? '7 days ago' : period === '30d' ? '30 days ago' : '90 days ago'"></span>
                    <span>Now</span>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</div>

<style>
  [x-cloak] { display: none !important; }
</style>
