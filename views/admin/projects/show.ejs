<div>
  <!-- Breadcrumb + Actions -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <div class="flex items-center gap-2 text-sm text-gray-500 mb-1">
        <a href="/admin" class="hover:text-blue-600">All Projects</a>
        <span>/</span>
        <span><%= website.name %></span>
      </div>
      <% if (website.base_url) { %>
        <p class="text-sm text-gray-400"><%= website.base_url %></p>
      <% } %>
    </div>
    <div class="flex gap-2">
      <a href="/admin/projects/<%= website.id %>/pages/new" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        Add Page
      </a>
      <a href="/admin/projects/<%= website.id %>/edit" class="px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 border border-gray-200">Edit</a>
      <form action="/admin/projects/<%= website.id %>/delete" method="POST" onsubmit="return confirm('Delete this project and ALL its pages?')" class="inline">
        <button type="submit" class="px-4 py-2 rounded-lg text-sm font-medium text-red-600 hover:bg-red-50 border border-red-200">Delete</button>
      </form>
    </div>
  </div>

  <!-- Assigned Users -->
  <% if (assignedUsers.length > 0) { %>
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 mb-6 flex items-center gap-2">
      <svg class="w-4 h-4 text-blue-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
      <span class="text-sm text-blue-700">Assigned to: <strong><%= assignedUsers.map(u => u.name).join(', ') %></strong></span>
    </div>
  <% } %>

  <!-- Pages List -->
  <% if (monitors.length === 0) { %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center">
      <h3 class="text-lg font-medium text-gray-600 mb-2">No pages added yet</h3>
      <p class="text-gray-400 mb-4">Add pages (URLs, ports, etc.) to monitor for this project</p>
      <a href="/admin/projects/<%= website.id %>/pages/new" class="inline-flex items-center gap-2 bg-blue-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700">Add Page</a>
    </div>
  <% } else { %>
    <div class="space-y-4">
      <% monitors.forEach(function(monitor) { %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
          <!-- Header row -->
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-3">
              <% if (monitor.status === 'up') { %>
                <span class="w-3 h-3 rounded-full bg-green-500"></span>
              <% } else if (monitor.status === 'down') { %>
                <span class="w-3 h-3 rounded-full bg-red-500 animate-pulse"></span>
              <% } else if (monitor.status === 'paused') { %>
                <span class="w-3 h-3 rounded-full bg-gray-300"></span>
              <% } else { %>
                <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
              <% } %>
              <div>
                <span class="font-semibold text-gray-800"><%= monitor.name %></span>
                <span class="text-xs text-gray-400 ml-2 uppercase bg-gray-100 px-1.5 py-0.5 rounded"><%= monitor.type %></span>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="px-2 py-0.5 rounded text-xs font-medium
                <%= monitor.status === 'up' ? 'bg-green-100 text-green-700' :
                   monitor.status === 'down' ? 'bg-red-100 text-red-700' :
                   monitor.status === 'paused' ? 'bg-gray-100 text-gray-500' :
                   'bg-yellow-100 text-yellow-700' %>"><%= monitor.status.toUpperCase() %></span>
              <form action="/admin/projects/<%= website.id %>/pages/<%= monitor.id %>/toggle" method="POST" class="inline">
                <button type="submit" class="text-xs px-2 py-1 rounded border <%= monitor.is_active ? 'text-yellow-600 border-yellow-200 hover:bg-yellow-50' : 'text-green-600 border-green-200 hover:bg-green-50' %>">
                  <%= monitor.is_active ? 'Pause' : 'Resume' %>
                </button>
              </form>
              <form action="/admin/projects/<%= website.id %>/pages/<%= monitor.id %>/delete" method="POST" onsubmit="return confirm('Delete this page?')" class="inline">
                <button type="submit" class="text-xs px-2 py-1 rounded border text-red-600 border-red-200 hover:bg-red-50">Delete</button>
              </form>
            </div>
          </div>

          <!-- URL / Target -->
          <div class="text-sm text-gray-500 mb-3">
            <% if (monitor.url) { %><%= monitor.url %><% } %>
            <% if (monitor.hostname) { %><%= monitor.hostname %><% if (monitor.port) { %>:<%= monitor.port %><% } %><% } %>
            <% if (monitor.keyword) { %> | Keyword: "<%= monitor.keyword %>" (<%= monitor.keyword_type %>)<% } %>
            &middot; Every <%= Math.round(monitor.interval_seconds / 60) %>min
          </div>

          <!-- Stats row -->
          <div class="grid grid-cols-4 gap-3 mb-3">
            <div class="text-center p-2 bg-gray-50 rounded">
              <div class="text-xs text-gray-400">24h</div>
              <div class="text-sm font-bold <%= monitor.stats && monitor.stats.uptime_24h >= 99 ? 'text-green-600' : 'text-red-600' %>"><%= monitor.stats && monitor.stats.uptime_24h ? monitor.stats.uptime_24h + '%' : 'N/A' %></div>
            </div>
            <div class="text-center p-2 bg-gray-50 rounded">
              <div class="text-xs text-gray-400">7d</div>
              <div class="text-sm font-bold <%= monitor.stats && monitor.stats.uptime_7d >= 99 ? 'text-green-600' : 'text-red-600' %>"><%= monitor.stats && monitor.stats.uptime_7d ? monitor.stats.uptime_7d + '%' : 'N/A' %></div>
            </div>
            <div class="text-center p-2 bg-gray-50 rounded">
              <div class="text-xs text-gray-400">30d</div>
              <div class="text-sm font-bold <%= monitor.stats && monitor.stats.uptime_30d >= 99 ? 'text-green-600' : 'text-red-600' %>"><%= monitor.stats && monitor.stats.uptime_30d ? monitor.stats.uptime_30d + '%' : 'N/A' %></div>
            </div>
            <div class="text-center p-2 bg-gray-50 rounded">
              <div class="text-xs text-gray-400">Resp</div>
              <div class="text-sm font-bold text-gray-700"><%= monitor.stats && monitor.stats.avg_response_24h ? monitor.stats.avg_response_24h + 'ms' : 'N/A' %></div>
            </div>
          </div>

          <!-- 90-day uptime bar -->
          <%- include('../../partials/uptime-bar', { dailyUptime: monitor.dailyUptime }) %>

          <% if (monitor.lastCheck) { %>
            <div class="text-xs text-gray-400 mt-2">Last checked: <%= timeAgo(monitor.lastCheck.checked_at) %> &middot; <%= formatResponseTime(monitor.lastCheck.response_time) %></div>
          <% } %>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>
