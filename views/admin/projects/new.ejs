<div class="max-w-lg fade-in">
  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
    <h2 class="text-lg font-semibold text-slate-800 mb-4">Add New Project</h2>
    <form action="/admin/projects" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Project Name *</label>
        <input type="text" name="name" required class="w-full px-3 py-2 border border-slate-300 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none" placeholder="My Website">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1">Base URL</label>
        <input type="url" name="base_url" class="w-full px-3 py-2 border border-slate-300 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none" placeholder="https://example.com">
        <p class="text-xs text-slate-400 mt-1">Auto-fills when adding pages</p>
      </div>

      <div class="pt-3 border-t border-slate-100">
        <label class="block text-sm font-medium text-slate-700 mb-1">
          <i data-lucide="file-text" class="w-4 h-4 inline-block align-middle"></i> Sitemap URLs
        </label>
        <textarea name="sitemaps" rows="3" class="w-full px-3 py-2 border border-slate-300 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none text-sm" placeholder="https://example.com/sitemap.xml&#10;https://example.com/sitemap-pages.xml&#10;(one per line)"></textarea>
        <p class="text-xs text-slate-400 mt-1">Pages from sitemap will be auto-imported as monitors. One URL per line.</p>
      </div>

      <div>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="sitemap_auto_sync" class="rounded border-slate-300 text-primary-600 focus:ring-primary-500 w-4 h-4">
          <span class="text-sm text-slate-700">Auto-sync sitemaps daily</span>
        </label>
        <p class="text-xs text-slate-400 mt-1 ml-6">New pages added to sitemap will be automatically monitored</p>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="bg-gradient-to-r from-primary-600 to-primary-700 text-white px-6 py-2 rounded-xl font-medium hover:from-primary-700 hover:to-primary-800 shadow-sm shadow-primary-500/25">Create Project</button>
        <a href="/admin" class="px-6 py-2 rounded-xl font-medium text-slate-600 hover:bg-slate-100">Cancel</a>
      </div>
    </form>
  </div>
</div>
