<div x-data="{ activeProject: '<%= websites.length > 0 ? websites[0].id : '' %>', device: 'desktop', period: '24h' }">

  <!-- Project Selector Buttons -->
  <div class="flex flex-wrap gap-2 mb-5">
    <% websites.forEach(function(website) { %>
      <button @click="activeProject = '<%= website.id %>'"
        :class="activeProject === '<%= website.id %>' ? 'bg-primary-600 text-white shadow-sm shadow-primary-500/25' : 'bg-white text-slate-600 border border-slate-200 hover:border-primary-300 hover:text-primary-600'"
        class="px-4 py-2 rounded-xl text-sm font-semibold transition-all flex items-center gap-2">
        <span class="w-2 h-2 rounded-full flex-shrink-0
          <%= parseInt(website.down_count) > 0 ? 'bg-red-400' : parseInt(website.monitor_count) === 0 ? 'bg-slate-300' : 'bg-emerald-400' %>"></span>
        <%= website.name %>
        <span class="text-[10px] opacity-70">(<%= website.monitor_count %>)</span>
      </button>
    <% }); %>
  </div>

  <!-- Filters -->
  <div class="flex items-center justify-between mb-3">
    <div class="flex items-center gap-1.5">
      <span class="text-xs font-medium text-slate-500">Period:</span>
      <div class="inline-flex items-center bg-slate-100 rounded-lg p-0.5">
        <% ['24h', '7d', '30d', '90d'].forEach(function(r) { %>
          <button @click="period = '<%= r %>'"
            :class="period === '<%= r %>' ? 'bg-white shadow-sm text-slate-800' : 'text-slate-500 hover:text-slate-700'"
            class="px-2.5 py-1 rounded-md text-[11px] font-semibold transition-all"><%= r === '24h' ? '24 Hours' : r === '7d' ? '7 Days' : r === '30d' ? '30 Days' : '90 Days' %></button>
        <% }); %>
      </div>
    </div>
    <div class="inline-flex items-center bg-slate-100 rounded-lg p-0.5">
      <button @click="device = 'desktop'"
        :class="device === 'desktop' ? 'bg-white shadow-sm text-slate-800' : 'text-slate-500 hover:text-slate-700'"
        class="flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[11px] font-semibold transition-all">
        <i data-lucide="monitor" class="w-3.5 h-3.5"></i> Desktop
      </button>
      <button @click="device = 'mobile'"
        :class="device === 'mobile' ? 'bg-white shadow-sm text-slate-800' : 'text-slate-500 hover:text-slate-700'"
        class="flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[11px] font-semibold transition-all">
        <i data-lucide="smartphone" class="w-3.5 h-3.5"></i> Mobile
      </button>
    </div>
  </div>

  <%
    function sc2(val) {
      if (val === null || val === undefined) return 'text-slate-300';
      if (val >= 90) return 'text-emerald-600 bg-emerald-50';
      if (val >= 50) return 'text-amber-600 bg-amber-50';
      return 'text-red-600 bg-red-50';
    }
    function lc2(val) {
      if (!val) return 'text-slate-300';
      if (val <= 2.5) return 'text-emerald-600';
      if (val <= 4) return 'text-amber-600';
      return 'text-red-600';
    }
    function cc2(val) {
      if (val === null || val === undefined) return 'text-slate-300';
      if (val <= 0.1) return 'text-emerald-600';
      if (val <= 0.25) return 'text-amber-600';
      return 'text-red-600';
    }
  %>

  <!-- Project Tables -->
  <% websites.forEach(function(website) { %>
    <div x-show="activeProject === '<%= website.id %>'" x-cloak>
      <% var monitors = projectMonitors[website.id] || []; %>
      <% if (monitors.length === 0) { %>
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-12 text-center">
          <p class="text-slate-400">No pages in this project</p>
        </div>
      <% } else { %>
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-200">
                  <th class="text-left px-4 py-3 text-xs font-semibold text-slate-600">Page</th>
                  <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">Uptime</th>
                  <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">Response</th>
                  <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">Performance</th>
                  <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">Accessibility</th>
                  <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">Best Practices</th>
                  <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">SEO</th>
                  <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">LCP</th>
                  <th class="text-center px-2 py-3 text-xs font-semibold text-slate-600">CLS</th>
                </tr>
              </thead>
              <tbody>
                <% monitors.forEach(function(monitor, index) { %>
                  <%
                    var ps = monitor.pagespeed && monitor.pagespeed['24h'] ? monitor.pagespeed['24h'] : null;
                    var psData = {};
                    if (monitor.pagespeed) {
                      ['mobile','desktop'].forEach(function(s) {
                        var d = ps ? ps[s] : null;
                        psData[s] = d ? { performance: parseInt(d.performance)||null, accessibility: parseInt(d.accessibility)||null, best_practices: parseInt(d.best_practices)||null, seo: parseInt(d.seo)||null, lcp: d.lcp?parseFloat(d.lcp):null, cls: d.cls!==null?parseFloat(d.cls):null } : null;
                      });
                    }
                  %>
                  <tr class="<%= index < monitors.length - 1 ? 'border-b border-slate-100' : '' %> hover:bg-slate-50/50 transition-colors"
                    x-data='{
                      stats: <%= JSON.stringify({ uptime_24h: monitor.stats?.uptime_24h||null, uptime_7d: monitor.stats?.uptime_7d||null, uptime_30d: monitor.stats?.uptime_30d||null, uptime_90d: monitor.stats?.uptime_90d||null }) %>,
                      ps: <%= JSON.stringify(psData) %>,
                      g(f) { let d = this.ps[device]; return d ? d[f] : null; },
                      sc(v) { if(!v&&v!==0) return "text-slate-300"; if(v>=90) return "text-emerald-600 bg-emerald-50"; if(v>=50) return "text-amber-600 bg-amber-50"; return "text-red-600 bg-red-50"; },
                      lc(v) { if(!v) return "text-slate-300"; if(v<=2.5) return "text-emerald-600"; if(v<=4) return "text-amber-600"; return "text-red-600"; },
                      cc(v) { if(v===null||v===undefined) return "text-slate-300"; if(v<=0.1) return "text-emerald-600"; if(v<=0.25) return "text-amber-600"; return "text-red-600"; }
                    }'>
                    <td class="px-4 py-2.5">
                      <div class="flex items-center gap-2 min-w-0">
                        <span class="w-2 h-2 rounded-full flex-shrink-0 <%= monitor.status === 'up' ? 'bg-emerald-500' : monitor.status === 'down' ? 'bg-red-500 status-pulse' : 'bg-slate-300' %>"></span>
                        <div class="min-w-0">
                          <div class="flex items-center gap-1.5">
                            <span class="text-sm font-medium text-slate-700 truncate max-w-[180px]"><%= monitor.name %></span>
                            <% if (monitor.url) { %>
                              <a href="<%= monitor.url %>" target="_blank" class="text-slate-400 hover:text-primary-600 flex-shrink-0"><i data-lucide="external-link" class="w-3 h-3"></i></a>
                            <% } %>
                          </div>
                          <div class="text-[10px] text-slate-400 truncate max-w-[200px]">
                            <% if (monitor.url) { %><%= monitor.url.replace(/^https?:\/\//, '') %><% } %>
                          </div>
                          <% if (monitor.status === 'down' && monitor.lastCheck && monitor.lastCheck.error_message) { %>
                            <div class="text-[10px] text-red-500 truncate max-w-[200px] mt-0.5"><%= monitor.lastCheck.error_message %></div>
                          <% } %>
                        </div>
                      </div>
                    </td>
                    <td class="px-2 py-2.5 text-center">
                      <span class="text-xs font-bold" :class="{ 'text-emerald-600': stats['uptime_'+period]>=99, 'text-red-600': stats['uptime_'+period]&&stats['uptime_'+period]<99, 'text-slate-400': !stats['uptime_'+period] }" x-text="stats['uptime_'+period] ? stats['uptime_'+period]+'%' : '-'"></span>
                    </td>
                    <td class="px-2 py-2.5 text-center">
                      <span class="text-xs font-bold text-slate-600"><%= monitor.stats?.avg_response_24h ? monitor.stats.avg_response_24h+'ms' : '-' %></span>
                    </td>
                    <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold px-1.5 py-0.5 rounded" :class="sc(g('performance'))" x-text="g('performance')!==null ? g('performance') : '-'"></span></td>
                    <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold px-1.5 py-0.5 rounded" :class="sc(g('accessibility'))" x-text="g('accessibility')!==null ? g('accessibility') : '-'"></span></td>
                    <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold px-1.5 py-0.5 rounded" :class="sc(g('best_practices'))" x-text="g('best_practices')!==null ? g('best_practices') : '-'"></span></td>
                    <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold px-1.5 py-0.5 rounded" :class="sc(g('seo'))" x-text="g('seo')!==null ? g('seo') : '-'"></span></td>
                    <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold" :class="lc(g('lcp'))" x-text="g('lcp')!==null ? g('lcp')+'s' : '-'"></span></td>
                    <td class="px-2 py-2.5 text-center"><span class="text-[11px] font-bold" :class="cc(g('cls'))" x-text="g('cls')!==null ? g('cls') : '-'"></span></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>
    </div>
  <% }); %>
</div>
