<div class="fade-in">
  <div class="flex justify-between items-center mb-6">
    <h2 class="text-base font-semibold text-slate-700">User Management</h2>
    <span class="text-sm text-slate-400"><%= users.length %> users</span>
  </div>

  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-slate-50 border-b border-slate-200">
          <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">User</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Role</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Projects</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Joined</th>
          <th class="px-6 py-3 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% users.forEach(function(u) { %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-6 py-4">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-gradient-to-br from-primary-400 to-purple-500 flex items-center justify-center text-white text-sm font-bold flex-shrink-0"><%= u.name.charAt(0).toUpperCase() %></div>
                <div>
                  <div class="font-medium text-slate-800"><%= u.name %></div>
                  <div class="text-xs text-slate-400"><%= u.email %></div>
                </div>
              </div>
            </td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center gap-1 px-2 py-1 rounded-lg text-xs font-semibold
                <%= u.role === 'admin' ? 'bg-primary-50 text-primary-700' : 'bg-slate-100 text-slate-600' %>">
                <i data-lucide="<%= u.role === 'admin' ? 'shield' : 'user' %>" class="w-3 h-3"></i>
                <%= u.role.charAt(0).toUpperCase() + u.role.slice(1) %>
              </span>
            </td>
            <td class="px-6 py-4 text-slate-500"><%= u.assigned_projects %> projects</td>
            <td class="px-6 py-4 text-slate-400 text-xs"><%= timeAgo(u.created_at) %></td>
            <td class="px-6 py-4 text-right">
              <div class="flex items-center justify-end gap-1">
                <a href="/admin/users/<%= u.id %>" class="p-1.5 rounded-lg hover:bg-primary-50 text-slate-400 hover:text-primary-600 transition-colors" title="Manage">
                  <i data-lucide="settings-2" class="w-4 h-4"></i>
                </a>
                <% if (u.id !== user.id) { %>
                  <form action="/admin/users/<%= u.id %>/toggle-role" method="POST" class="inline">
                    <button type="submit" class="p-1.5 rounded-lg hover:bg-purple-50 text-slate-400 hover:text-purple-600 transition-colors" title="<%= u.role === 'admin' ? 'Demote' : 'Make Admin' %>">
                      <i data-lucide="<%= u.role === 'admin' ? 'shield-off' : 'shield-check' %>" class="w-4 h-4"></i>
                    </button>
                  </form>
                  <form action="/admin/users/<%= u.id %>/delete" method="POST" onsubmit="return confirm('Delete this user?')" class="inline">
                    <button type="submit" class="p-1.5 rounded-lg hover:bg-red-50 text-slate-400 hover:text-red-500 transition-colors" title="Delete">
                      <i data-lucide="trash-2" class="w-4 h-4"></i>
                    </button>
                  </form>
                <% } else { %>
                  <span class="text-[10px] font-medium text-slate-400 px-2">(you)</span>
                <% } %>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
