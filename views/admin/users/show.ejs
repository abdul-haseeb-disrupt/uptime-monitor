<div class="max-w-2xl">
  <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
    <a href="/admin/users" class="hover:text-blue-600">Users</a>
    <span>/</span>
    <span><%= targetUser.name %></span>
  </div>

  <!-- User Info -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
    <div class="flex items-center justify-between">
      <div>
        <h2 class="text-xl font-bold text-gray-800"><%= targetUser.name %></h2>
        <p class="text-sm text-gray-500"><%= targetUser.email %></p>
      </div>
      <span class="px-3 py-1 rounded-lg text-sm font-medium <%= targetUser.role === 'admin' ? 'bg-purple-100 text-purple-700' : 'bg-gray-100 text-gray-600' %>">
        <%= targetUser.role.toUpperCase() %>
      </span>
    </div>
  </div>

  <!-- Project Assignments -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <h3 class="text-lg font-semibold text-gray-800 mb-4">Project Assignments</h3>
    <p class="text-sm text-gray-500 mb-4">Select which projects this user can see on their dashboard.</p>

    <form action="/admin/users/<%= targetUser.id %>/assignments" method="POST">
      <div class="space-y-2 max-h-80 overflow-y-auto border border-gray-200 rounded-lg p-3 mb-4">
        <% if (allProjects.length === 0) { %>
          <p class="text-sm text-gray-400 p-2">No projects created yet.</p>
        <% } else { %>
          <% allProjects.forEach(function(project) { %>
            <label class="flex items-center gap-3 py-2 px-3 rounded-lg hover:bg-gray-50 cursor-pointer">
              <input type="checkbox" name="project_ids" value="<%= project.id %>"
                <%= assignedIds.includes(project.id) ? 'checked' : '' %>
                class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 w-4 h-4">
              <div class="flex-1">
                <span class="text-sm font-medium text-gray-700"><%= project.name %></span>
                <% if (project.base_url) { %>
                  <span class="text-xs text-gray-400 ml-2"><%= project.base_url %></span>
                <% } %>
              </div>
            </label>
          <% }); %>
        <% } %>
      </div>

      <div class="flex gap-3">
        <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-700">Save Assignments</button>
        <a href="/admin/users" class="px-6 py-2 rounded-lg font-medium text-gray-600 hover:bg-gray-100">Cancel</a>
      </div>
    </form>
  </div>
</div>
