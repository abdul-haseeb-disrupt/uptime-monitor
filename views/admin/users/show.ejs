<div class="max-w-2xl fade-in">
  <div class="flex items-center gap-2 text-sm text-slate-400 mb-6">
    <a href="/admin/users" class="hover:text-primary-600 transition-colors">Users</a>
    <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
    <span class="text-slate-600 font-medium"><%= targetUser.name %></span>
  </div>

  <!-- User Info -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-6">
    <div class="flex items-center gap-4">
      <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary-400 to-purple-500 flex items-center justify-center text-white text-xl font-bold"><%= targetUser.name.charAt(0).toUpperCase() %></div>
      <div class="flex-1">
        <h2 class="text-xl font-bold text-slate-800"><%= targetUser.name %></h2>
        <p class="text-sm text-slate-400 flex items-center gap-1.5">
          <i data-lucide="mail" class="w-3.5 h-3.5"></i> <%= targetUser.email %>
        </p>
      </div>
      <span class="inline-flex items-center gap-1 px-3 py-1.5 rounded-xl text-sm font-semibold
        <%= targetUser.role === 'admin' ? 'bg-primary-50 text-primary-700' : 'bg-slate-100 text-slate-600' %>">
        <i data-lucide="<%= targetUser.role === 'admin' ? 'shield' : 'user' %>" class="w-4 h-4"></i>
        <%= targetUser.role.toUpperCase() %>
      </span>
    </div>
  </div>

  <!-- Project Assignments -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
    <div class="flex items-center gap-2 mb-1">
      <i data-lucide="folder" class="w-5 h-5 text-slate-400"></i>
      <h3 class="text-lg font-semibold text-slate-800">Project Assignments</h3>
    </div>
    <p class="text-sm text-slate-400 mb-5">Select which projects this user can see on their dashboard.</p>

    <form action="/admin/users/<%= targetUser.id %>/assignments" method="POST">
      <div class="space-y-1 max-h-80 overflow-y-auto border border-slate-200 rounded-xl p-2 mb-5">
        <% if (allProjects.length === 0) { %>
          <p class="text-sm text-slate-400 p-3">No projects created yet.</p>
        <% } else { %>
          <% allProjects.forEach(function(project) { %>
            <label class="flex items-center gap-3 py-2.5 px-3 rounded-xl hover:bg-slate-50 cursor-pointer transition-colors">
              <input type="checkbox" name="project_ids" value="<%= project.id %>"
                <%= assignedIds.includes(project.id) ? 'checked' : '' %>
                class="rounded border-slate-300 text-primary-600 focus:ring-primary-500 w-4 h-4">
              <div class="flex items-center gap-2 flex-1">
                <i data-lucide="globe" class="w-4 h-4 text-slate-400"></i>
                <span class="text-sm font-medium text-slate-700"><%= project.name %></span>
                <% if (project.base_url) { %>
                  <span class="text-xs text-slate-400 truncate"><%= project.base_url %></span>
                <% } %>
              </div>
            </label>
          <% }); %>
        <% } %>
      </div>

      <div class="flex gap-3">
        <button type="submit" class="bg-gradient-to-r from-primary-600 to-primary-700 text-white px-6 py-2.5 rounded-xl font-medium hover:from-primary-700 hover:to-primary-800 shadow-sm shadow-primary-500/25 transition-all">Save Assignments</button>
        <a href="/admin/users" class="px-6 py-2.5 rounded-xl font-medium text-slate-600 hover:bg-slate-100 transition-colors">Cancel</a>
      </div>
    </form>
  </div>
</div>
